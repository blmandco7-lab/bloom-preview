function issueBrandLoginCode(brandId) {
  var code = generateBrandCode();
  db.collection('studio-brand-directory').doc(brandId).get().then(function(doc){
    var brand = doc.exists ? doc.data() : {};
    var emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!brand.email || !emailPattern.test(brand.email)) {
      showToast('"'+(brand.email||'(empty)')+'" isn\'t a real email address — edit this brand and fix the contact email first.', 'error');
      return;
    }
    createRealAccountWithRole(brand.email, code, {role:'brand', linkedId: brandId, linkedName: brand.name}, function(){
      dbUpdate('studio-brand-directory', brandId, {accessCode: code}, function(){
        showToast('Real login created for '+brand.email);
        loadBrandDirectory();
        loadBrandAccounts();
      });
    }, function(err){
      showToast('Login setup failed: '+err.message, 'error');
    });
  });
}
// Note: resetting an existing login now works differently than before.
// Directly changing someone else's password requires server-side admin
// access we're deliberately not using (that's the Cloud Functions / Blaze
// requirement this whole approach avoids). Instead, this sends the brand
// a real password-reset email -- the standard, secure way to do this
// without a paid backend. They set their own new password from that link.
function regenerateBrandCode(brandId) {
  db.collection('studio-brand-directory').doc(brandId).get().then(function(doc){
    var brand = doc.exists ? doc.data() : {};
    if (!brand.email) { showToast('This brand has no contact email on file.', 'error'); return; }
    firebase.auth().sendPasswordResetEmail(brand.email).then(function(){
      showToast('Password reset email sent to '+brand.email);
    }).catch(function(err){
      showToast('Could not send reset email: '+err.message, 'error');
    });
  });
}
