var brandMsgAttachment = null;
function handleBrandMsgAttach(event) {
  var file = event.target.files[0];
  if (!file) return;
  if (file.size > 700000) { showToast('File too large — please keep attachments under 700KB','error'); return; }
  var reader = new FileReader();
  reader.onload = function(e) {
    brandMsgAttachment = {name: file.name, data: e.target.result, type: file.type};
    var preview = document.getElementById('brand-msg-attach-preview');
    if (preview) { preview.style.display = 'block'; preview.innerHTML = '<i class="ti ti-paperclip"></i> '+file.name+' <span style="cursor:pointer;color:var(--red)" onclick="brandMsgAttachment=null;document.getElementById(\'brand-msg-attach-preview\').style.display=\'none\'">✕</span>'; }
  };
  reader.readAsDataURL(file);
}
function loadBrandMessages() {
  var myBrand = (currentUser && currentUser.name) || null;
