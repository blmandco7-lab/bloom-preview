function recalcContentCalendarStats() {
  dbGet('studio-content-posts', function(docs) {
    docs = docs || [];
    var els0 = document.querySelectorAll('#s-content-calendar .sg .stat .sv');
    if (!docs.length) {
      els0.forEach(function(el){ el.textContent = '0'; });
      return;
    }
    var now = new Date();
    var today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    var weekStart = new Date(today);
    var weekEnd = new Date(weekStart.getTime()+7*86400000);
    var thisWeek=0, pending=0, liveToday=0, overdue=0;
    docs.forEach(function(d) {
      var dt = d.date ? new Date(d.date) : null;
      if (dt && dt>=weekStart && dt<weekEnd) thisWeek++;
      if (d.status==='Pending approval') pending++;
      if (dt && dt.toDateString()===today.toDateString() && (d.status==='Live'||d.status==='Posted')) liveToday++;
      if (dt && dt<today && d.status!=='Posted' && d.status!=='Live') overdue++;
    });
    var els = document.querySelectorAll('#s-content-calendar .sg .stat .sv');
    if (els[0]) els[0].textContent = thisWeek;
    if (els[1]) els[1].textContent = pending;
    if (els[2]) els[2].textContent = liveToday;
    if (els[3]) els[3].textContent = overdue;
  });
}
