function dbAdd(col, data, onSuccess, onError) {
  data._created = new Date().toISOString();
  data._updated = new Date().toISOString();
  function refreshCurrentScreen(){ try{ var k=navHistory[navHistory.length-1]; if(k) { universalLoadScreen(k); autoLoadScreen(k); } }catch(e3){} }
  if (db) {
    data._ts = firebase.firestore.FieldValue.serverTimestamp();
    db.collection(col).add(data)
      .then(function(ref) { 
        data.id = ref.id;
        refreshCurrentScreen();
        if (onSuccess) onSuccess(data); 
      })
      .catch(function(e) { 
        console.error('dbAdd error:', e);
        lsAdd(col, data); 
        refreshCurrentScreen();
        if (onSuccess) onSuccess(data);
      });
  } else {
    lsAdd(col, data);
    refreshCurrentScreen();
    if (onSuccess) onSuccess(data);
  }
}

function dbGetAll(col, onSuccess) {
  if (db) {
    db.collection(col).get()
      .then(function(snap) {
        var docs = [];
        snap.forEach(function(doc) { docs.push(Object.assign({id: doc.id}, doc.data())); });
        if (onSuccess) onSuccess(docs);
      })
      .catch(function(e) {
        console.error('dbGetAll error:', e);
        if (onSuccess) onSuccess(lsGet(col));
      });
  } else {
    if (onSuccess) onSuccess(lsGet(col));
  }
}
function dbGet(col, onSuccess, filter) {
  // Fetch newest-first (so a cap of 100 keeps the most recent records), then
  // reverse to oldest-first before handing off — every screen just renders this
  // array in order, so oldest-first means new entries land at the bottom of the
  // list instead of jumping to the top.
  if (db) {
    var q = db.collection(col).orderBy('_ts', 'desc').limit(100);
    q.get()
      .then(function(snap) {
        var docs = [];
        snap.forEach(function(doc) { docs.push(Object.assign({id: doc.id}, doc.data())); });
        docs.reverse();
        if (onSuccess) onSuccess(docs);
      })
      .catch(function(e) {
        console.error('dbGet error:', e);
        if (onSuccess) onSuccess(lsGet(col).slice().reverse());
      });
  } else {
    if (onSuccess) onSuccess(lsGet(col).slice().reverse());
  }
}

function dbDelete(col, id, onSuccess, onError) {
  if (db && id) {
    db.collection(col).doc(id).delete()
      .then(function() { if (onSuccess) onSuccess(); })
      .catch(function(e) {
        console.error('dbDelete error:', e);
        // Do NOT treat this as success: the record is still live in the shared
        // database even though this browser failed to delete it. Silently
        // "succeeding" here was why deleted rows kept reappearing after a
        // refresh — the local fade-out lied about what actually happened.
        if (onError) onError(e);
      });
  } else {
    lsDelete(col, id);
    if (onSuccess) onSuccess();
  }
}

function dbUpdate(col, id, data, onSuccess) {
  data._updated = new Date().toISOString();
  if (db && id) {
    db.collection(col).doc(id).update(data)
      .then(function() { if (onSuccess) onSuccess(); })
      .catch(function(e) { console.error('dbUpdate error:', e); lsUpdate(col, id, data); if (onSuccess) onSuccess(); });
  } else {
    lsUpdate(col, id, data);
    if (onSuccess) onSuccess();
  }
}
function lsUpdate(col, id, data) {
  try {
    var arr = lsGet(col);
    var idx = arr.findIndex(function(d){ return d.id === id; });
    if (idx !== -1) { Object.assign(arr[idx], data); localStorage.setItem(lsKey(col), JSON.stringify(arr)); }
  } catch(e) {}
}

// ── LOCALSTORAGE FALLBACK ──
function lsKey(col) { return 'bloom_' + col.replace('studio-','').replace(/-/g,'_'); }
function lsGet(col) { try { return JSON.parse(localStorage.getItem(lsKey(col)) || '[]'); } catch(e) { return []; } }
function lsAdd(col, data) { 
  try { 
    data.id = data.id || ('local_' + Date.now());
    var arr = lsGet(col); arr.unshift(data); 
    localStorage.setItem(lsKey(col), JSON.stringify(arr.slice(0, 500))); 
  } catch(e) {} 
}
function lsDelete(col, id) { 
  try { 
    var arr = lsGet(col).filter(function(d) { return d.id !== id; }); 
    localStorage.setItem(lsKey(col), JSON.stringify(arr)); 
  } catch(e) {} 
}
function lsSave(col, arr) { 
  try { localStorage.setItem(lsKey(col), JSON.stringify(arr)); } catch(e) {} 
}

