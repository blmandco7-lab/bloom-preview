function parseCount(str) {
  if (!str) return 0;
  str = String(str).trim().toUpperCase().replace(/,/g,'');
  var m = str.match(/^\$?([\d.]+)\s*([KM]?)/);
  if (!m) return 0;
  var num = parseFloat(m[1]) || 0;
  if (m[2]==='K') num *= 1000;
  if (m[2]==='M') num *= 1000000;
  return num;
}
function formatCount(num) {
  num = num || 0;
  if (num >= 1000000) return (num/1000000).toFixed(1).replace(/\.0$/,'')+'M';
  if (num >= 1000) return (num/1000).toFixed(1).replace(/\.0$/,'')+'K';
  return String(Math.round(num));
}
function recalcRevenueStats() {
  dbGet('studio-invoices', function(docs) {
    docs = docs || [];
    var svEls = document.querySelectorAll('#s-revenue .sg .stat .sv');
    if (!docs.length) {
      if (svEls[0]) svEls[0].textContent = '$0';
      if (svEls[1]) svEls[1].textContent = '$0';
      if (svEls[2]) svEls[2].textContent = '$0';
      if (svEls[3]) svEls[3].textContent = '—';
      return;
    }
    var now = new Date(); var mo = now.getMonth(); var yr = now.getFullYear();
    var thisMonthTotal = 0, allTotal = 0;
    docs.forEach(function(d) {
      var amt = parseFloat(d.amount||0);
      allTotal += amt;
      var dt = d._created ? new Date(d._created) : null;
      if (dt && dt.getMonth()===mo && dt.getFullYear()===yr) thisMonthTotal += amt;
    });
    var avgDeal = docs.length ? (allTotal/docs.length) : 0;
    var sdEls = document.querySelectorAll('#s-revenue .sg .stat .sd');
