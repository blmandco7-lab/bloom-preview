function openAddTeamMember() {
  // Creator / Agency partner / Sub-agency each have their own dedicated
  // add-flow now (Add Creator to roster, Add sub-agency, Add brand to
  // directory) which link a real account to their actual profile record.
  // This one stays focused on Agent / Agent Manager, which don't have a
  // separate profile collection beyond studio-team-members itself.
  showModal({title:'Add team member',icon:'user-plus',submit:'Create account',fields:[
    {label:'Full name',id:'name',placeholder:'e.g. Alex Jones'},
    {label:'Email (for their login)',id:'email',type:'email',placeholder:'name@email.com'},
    {label:'Role',id:'role',type:'select',options:['Agent','Agent Manager']},
    {label:'Access code',id:'accessCode',placeholder:'Leave blank to auto-generate'}
  ],onSubmit:function(d){
    var roleMap = {'Agent':'agent','Agent Manager':'agentmgr'};
    d.role = roleMap[d.role] || 'agent';
    if (!d.accessCode || !d.accessCode.trim()) {
      var prefix = {agent:'AGT',agentmgr:'MGR'}[d.role] || 'USR';
      d.accessCode = _randomAccessCode(prefix);
    }
    d.status = 'Active';
    var loginEmail = d.email; delete d.email;
    dbAdd('studio-team-members', d, function(saved){
      teamMembers.push(saved);
      try{localStorage.setItem('bloom_team_members', JSON.stringify(teamMembers));}catch(e){}
      showToast(d.name+"'s account created — code: "+d.accessCode);
      loadTeamMembersList();
      if (loginEmail) {
        createRealAccountWithRole(loginEmail, d.accessCode, {role:d.role, linkedId:saved.id, linkedName:d.name}, function(){
          showToast('Real login ready for '+d.name);
        }, function(err){
          showToast('Team record saved, but login setup failed: '+err.message, 'error');
        });
      }
    });
  }});
}
