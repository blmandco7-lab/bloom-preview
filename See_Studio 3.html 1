function applyMarketplaceFilters() {
  var niche = document.getElementById('mkt-niche').value;
  var platform = document.getElementById('mkt-platform').value;
  var size = document.getElementById('mkt-size').value;
  var tier = document.getElementById('mkt-tier').value;
  var sizeRanges = {'Under 100K':[0,100000],'100K – 500K':[100000,500000],'500K – 1M':[500000,1000000],'1M+':[1000000,Infinity]};
  var cards = document.querySelectorAll('#marketplace-demo-cards .panel[data-niche]');
  var visibleCount = 0;
  cards.forEach(function(card) {
    var cardNiche = card.getAttribute('data-niche') || '';
    var cardPlatform = card.getAttribute('data-platform') || '';
    var cardReach = parseFloat(card.getAttribute('data-reach')) || 0;
    var cardTier = card.getAttribute('data-tier') || '';
    var match = true;
    if (niche && cardNiche !== niche) match = false;
    if (platform && cardPlatform.indexOf(platform) === -1) match = false;
    if (size && sizeRanges[size] && (cardReach < sizeRanges[size][0] || cardReach >= sizeRanges[size][1])) match = false;
    if (tier && cardTier !== tier) match = false;
    card.style.display = match ? '' : 'none';
    if (match) visibleCount++;
  });
  showToast(visibleCount+' creator'+(visibleCount!==1?'s':'')+' match'+(visibleCount===1?'es':'')+' your filters');
}
