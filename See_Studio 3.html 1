  // not to brands, matching how the rest of the app treats external roles.
  var map = {
    director:  ['Creator','Brand','Agent','Agent Manager','Director — Internal','All staff','General'],
    agentmgr:  ['Agent','Agent Manager','All staff','General'],
    agent:     ['Agent','All staff','General'],
    creator:   ['Creator','General'],
    brand:     ['Brand','General'],
    agency:    ['All staff','General'],
    subagency: ['All staff','General']
  };
  return map[currentRole] || ['General'];
}
function loadKBArticles() {
  // Load built-in articles + any saved to Firebase
  var el = document.getElementById('kb-articles-list');
