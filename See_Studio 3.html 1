// ── PASSWORDS ──
// IMPORTANT — read this before relying on this login system for real client data:
// This is a shared "PIN" model, not real authentication. The current codes always
// exist in this JS (whether hardcoded or fetched from Firestore) because the
// browser itself has to be able to check what the user typed against them. Anyone
// who opens devtools can read the `passwords` variable directly, or just call
// finishTeamLogin('director') in the console and skip the check entirely. That is
// true no matter how the codes are stored client-side. Treat this as "keeps
// honest people out," not as real access control, until it's backed by real
// server-side auth (e.g. Firebase Authentication + custom claims checked in
// Firestore security rules) that verifies the code on a server you control.
var currentUser = null; // set when an individual (not shared-role) account logs in: {id,name,handle,role,accessCode}
var teamMembers = []; // individual accounts, loaded from Firestore/localStorage
var brandAccounts = []; // individual brand client accounts with their own login codes
var brandSubUsers = []; // sub-accounts within a brand (media buyer, creative director, legal)
function _randomAccessCode(prefix) {
  var chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789'; // no 0/O, 1/I/L — avoids hand-typing mixups
  var code = '';
  for (var i = 0; i < 8; i++) code += chars[Math.floor(Math.random() * chars.length)];
  return prefix + '-' + code;
}
// Every "Example listing" section in this app is a label followed by hardcoded
// demo rows as plain sibling elements. The old code only ever hid the label
// itself, so the fake rows stayed on screen forever even once real data
// existed. This hides/shows the label AND every sibling after it (the actual
// fake rows), so real data fully replaces the placeholder instead of sitting
// above/below it.
function _toggleExampleBlock(label, show) {
  if (!label) return;
  var disp = show ? '' : 'none';
  label.style.display = disp;
  var el = label.nextElementSibling;
  while (el) { el.style.display = disp; el = el.nextElementSibling; }
}
// Every deployment of this app now gets its own random starting codes instead of
// the same fixed defaults (e.g. 'BLM-DIRECTOR-2026') that would otherwise be
// identical — and guessable — across every copy of this template that hasn't
// changed them yet. loadPasswordsIntoLogin() below will overwrite these with
// whatever is actually saved in Firestore/localStorage for returning users.
