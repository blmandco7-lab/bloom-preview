// ---- Creator's own Earnings summary: real MTD and pending totals ----
function loadCreatorEarningsStats() {
  if (!currentUser) return;
  var matchVal = currentUser.handle || currentUser.name;
  var mtdEl = document.getElementById('cearn-mtd');
  var pendingEl = document.getElementById('cearn-pending');
  dbGet('studio-payments', function (docs) {
    var mine = (docs || []).filter(function (d) { return d.creator === matchVal; });
    var now = new Date();
    var mtd = mine.filter(function (d) {
      var dt = d._created ? new Date(d._created) : null;
      return dt && dt.getMonth() === now.getMonth() && dt.getFullYear() === now.getFullYear();
    }).reduce(function (sum, d) { return sum + (Number(d.amount) || 0); }, 0);
    var pending = mine.filter(function (d) { return d.status && d.status !== 'Paid'; })
      .reduce(function (sum, d) { return sum + (Number(d.amount) || 0); }, 0);
    if (mtdEl) mtdEl.textContent = '$' + mtd.toLocaleString();
    if (pendingEl) pendingEl.textContent = '$' + pending.toLocaleString();
  });
}

