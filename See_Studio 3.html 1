function cycleDealStage(id) {
  dbGet(COLS.deals, function (docs) {
    var d = (docs || []).find(function (x) { return x.id === id; });
    if (!d) return;
    var order = ['Lead', 'Pitched', 'Negotiating', 'Contracted', 'Live', 'Completed'];
    var idx = order.indexOf(d.stage);
    if (idx === -1) idx = 0;
    var next = order[Math.min(idx + 1, order.length - 1)];
    dbUpdate(COLS.deals, id, { stage: next }, function () {
      showToast('Stage: '+next);
      loadDeals(); recalcAllDealsStats();
      try { recalcPipelineStats(); } catch(e) {}
      // This is the part that was only ever claimed in the copy, never
      // actually built: generate a real invoice the moment a deal reaches
      // Completed, instead of requiring someone to remember to do it.
      if (next === 'Completed' && !d.invoiceGenerated) {
        var invoice = { to: d.brand, forWork: (d.creator||'')+' — '+(d.platform||'deal'), amount: d.budget, due: new Date(Date.now()+14*86400000).toISOString().slice(0,10), status: 'Pending' };
        dbAdd('studio-invoices', invoice, function () {
          dbUpdate(COLS.deals, id, { invoiceGenerated: true }, function(){});
          showToast('Invoice auto-generated for '+(d.brand||'this deal'));
          addNotificationForDirector('Invoice auto-generated', 'Deal with '+(d.brand||'a brand')+' reached Completed — a $'+(parseInt(d.budget||0)).toLocaleString()+' invoice was created automatically.', 'success');
        });
      }
    });
  });
}
