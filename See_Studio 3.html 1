function _downloadContractComposer() {
  var text = document.getElementById('cc-text').value;
  var party = document.getElementById('cc-party').value || 'contract';
  var blob = new Blob([text], { type: 'text/plain' });
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a'); a.href = url; a.download = party.replace(/\s+/g,'-').toLowerCase() + '-contract.txt';
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  URL.revokeObjectURL(url);
  showToast('Contract downloaded');
}
function _copyContractComposer() {
  var text = document.getElementById('cc-text').value;
  if (navigator.clipboard) { navigator.clipboard.writeText(text).then(function () { showToast('Copied — paste it anywhere to send'); }); }
  else { showToast('Copy not supported on this browser', 'error'); }
}
function _saveContractComposerToTracker() {
  var type = document.getElementById('cc-type').value;
  var party = document.getElementById('cc-party').value;
  var text = document.getElementById('cc-text').value;
  dbAdd('studio-contracts', { type: type==='Blank'?'Custom':type, party: party, terms: text.substring(0, 500), fullText: text }, function () {
    showToast('Saved to your contracts tracker');
    logAuditEvent('Contract composed', (type||'Contract')+' for '+(party||'party'), currentRole);
    try { loadContracts(); } catch (e) {}
    closeModal();
  });
}
