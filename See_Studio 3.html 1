function openAddPaymentRecord() {
  var savedRate = '10';
  try { var cs = JSON.parse(localStorage.getItem('bloom_commission_structure')||'null'); if (cs && cs['cs-standard']) savedRate = cs['cs-standard']; } catch(e) {}
  showModal({title:'Log payment',icon:'receipt',submit:'Save payment',fields:[
    {label:'Creator handle',id:'creator',placeholder:'@username'},
    {label:'Brand',id:'brand',placeholder:'Brand name'},
    {label:'Deal amount ($)',id:'deal',type:'number',placeholder:'e.g. 4200'},
    {label:'Creator payout ($)',id:'payout',type:'number',placeholder:'e.g. 3276'},
    {label:'Agency commission ($) — your standard rate is '+savedRate+'%',id:'commission',type:'number',placeholder:'e.g. 924'},
    {label:'Payment date',id:'date',type:'date'},
    {label:'Status',id:'status',type:'select',options:['Paid','Pending','Overdue']}
  ],onSubmit:function(d){
    if (!d.creator || !d.creator.trim()) { showToast('Enter a creator handle first','error'); return; }
    dbGet(COLS.payments, function (existingPayments) {
      var handle = d.creator.trim().toLowerCase();
      var year = new Date(d.date || Date.now()).getFullYear();
      var priorTotal = (existingPayments || []).filter(function (p) {
        return (p.creator||'').trim().toLowerCase() === handle && p.date && new Date(p.date).getFullYear() === year;
      }).reduce(function (sum, p) { return sum + (parseFloat(p.payout) || 0); }, 0);
      var newTotal = priorTotal + (parseFloat(d.payout) || 0);
      if (newTotal < 600) {
        // Under the real IRS 1099-NEC threshold for the year -- a W-9 isn't
        // actually required yet, so this should go through, not get blocked
        // just because a form hasn't been collected.
        dbAdd(COLS.payments, d, function(){ showToast('Payment recorded for '+(d.creator||'creator')); loadPaymentRecords(); autoScheduleFromPayout(d); });
        return;
      }
      dbGet(COLS.w9s, function(w9docs) {
        var match = (w9docs||[]).find(function(w){ return (w.creator||'').trim().toLowerCase() === handle && w.status === 'On file'; });
        if (!match) {
          showToast('Payment blocked — '+(d.creator||'this creator')+' has crossed $600 for the year ($'+newTotal.toLocaleString()+'), which requires a W-9 on file before paying further. Add one in the W-9 Tracker first.', 'error');
          return;
        }
        dbAdd(COLS.payments, d, function(){ showToast('Payment recorded for '+(d.creator||'creator')); loadPaymentRecords(); autoScheduleFromPayout(d); });
      });
    });
  }});
}
