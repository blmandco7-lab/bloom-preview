      if (data.error) { if(feed) feed.innerHTML = '<div style="padding:20px;color:var(--red);font-size:12px">API Error: ' + data.error.message + '</div>'; return; }
      if (!data.items || !data.items.length) { if(feed) feed.innerHTML = '<div style="padding:20px;color:var(--text3);text-align:center">No results found.</div>'; return; }
      var ids = data.items.map(function(x){ return x.id.channelId; }).join(',');
