      else if (eng > 0) lines.push({ icon: 'alert-triangle', color: 'var(--amber)', text: 'Engagement rate of ' + eng + '% is on the lower side — worth a manual look before a big deal' });
      else lines.push({ icon: 'info-circle', color: 'var(--text3)', text: 'No engagement rate on file yet' });
      lines.push({ icon: 'info-circle', color: 'var(--text3)', text: 'Signed ' + (d._created ? Math.max(0, Math.round((Date.now() - new Date(d._created).getTime()) / 86400000)) + ' days ago' : 'recently') });
