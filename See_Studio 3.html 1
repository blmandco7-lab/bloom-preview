var _modalCb = null;
function showModal(cfg) {
  var m = document.getElementById('actionModal');
  if (!m) return;
  var el = function(id){ return document.getElementById(id); };
  var icon = el('modalIcon'); if(icon) { icon.className = 'ti ti-'+(cfg.icon||'plus'); icon.style.color='var(--gold)'; }
  var title = el('modalTitle'); if(title) title.textContent = cfg.title||'';
  var desc = el('modalDesc'); if(desc) { desc.textContent=cfg.desc||''; desc.style.display=cfg.desc?'block':'none'; }
  var btn = el('modalSubmitBtn');
  if (btn) { btn.textContent = cfg.submit||'Save'; btn.style.display = (cfg.submit===null) ? 'none' : ''; }
  _modalCb = cfg.onSubmit || null;
  var fields = el('modalFields');
  if (fields) {
    if (cfg.customBody) {
      fields.innerHTML = cfg.customBody;
    } else {
      fields.innerHTML = (cfg.fields||[]).map(function(f) {
        var inp = '';
