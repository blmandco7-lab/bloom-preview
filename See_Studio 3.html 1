function generateRetainerInvoices() {
  dbGet('studio-retainers', function (docs) {
    var today = new Date().toISOString().slice(0, 10);
    var due = (docs || []).filter(function (d) { return d.nextDue && d.nextDue <= today && !d.lastInvoiced; });
    if (!due.length) { showToast('No retainer invoices due right now', 'info'); return; }
    var created = 0;
    due.forEach(function (d) {
      var invoice = { to: d.brand, forWork: 'Monthly retainer', amount: d.monthly, due: d.nextDue, status: 'Pending' };
      dbAdd('studio-invoices', invoice, function () {
        var nextMonth = new Date(d.nextDue);
        nextMonth.setMonth(nextMonth.getMonth() + 1);
        dbUpdate('studio-retainers', d.id, { lastInvoiced: today, nextDue: nextMonth.toISOString().slice(0, 10) }, function () {
