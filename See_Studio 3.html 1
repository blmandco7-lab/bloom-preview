      e('cp-missions', (missions || []).filter(function (m) { return m.creator === handle && m.status !== 'Completed'; }).length);
    });
    dbGet('studio-deals', function (deals) {
      e('cp-deals', (deals || []).filter(function (dl) { return dl.creator === handle && dl.stage !== 'Complete' && dl.stage !== 'Completed'; }).length);
    });
    e('cp-tenure', d._created ? Math.max(0, Math.round((Date.now() - new Date(d._created).getTime()) / 86400000)) + 'd' : '—');

    dbGet('studio-brand-directory', function (brands) {
      var matchEl = document.getElementById('cp-brand-matches');
