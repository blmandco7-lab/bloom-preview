function askKBQuestion(inputId, outputId) {
  var inp = document.getElementById(inputId || 'kb-question-input');
  var out = document.getElementById(outputId || 'kb-answer-out');
  if (!inp || !inp.value.trim()) return;
  var q = inp.value.trim();
  if (!out) return;
  out.style.display = 'block';
  out.textContent = 'Finding your answer...';

  function ask(allArticles) {
    var visible = _kbVisibleSections();
    var relevant = allArticles.filter(function (a) { return visible.indexOf(a.section || 'General') !== -1; });
    var context = relevant.map(function(a){ return a.title + ': ' + a.content; }).join('\n\n');
    var prompt = 'You are the See Network talent agency assistant. Answer this question using the knowledge base below. Be clear, friendly, and specific. If the answer is in the knowledge base, quote the relevant policy. If nothing below answers it, say so plainly instead of guessing. Question: ' + q + '\n\nKnowledge base:\n' + context;
    callGemini(prompt, function(text){
      out.textContent = text || 'No answer found.';
    }, function(err){
      // Show the REAL error instead of always blaming a missing key --
      // a wrong/expired key, an unavailable model, or a network issue all
      // look identical to the old version of this function.
      out.textContent = 'Could not get an answer: ' + (err || 'unknown error') + '. If this keeps happening, check the Gemini key and model name in Integrations.';
    });
  }

  if (db) {
    db.collection('studio-knowledge-base').orderBy('_ts','desc').get()
      .then(function (snap) {
        var extra = [];
        snap.forEach(function (doc) { extra.push(Object.assign({ id: doc.id }, doc.data())); });
        ask(_kbArticles.concat(extra));
      })
      .catch(function () { ask(_kbArticles); });
  } else {
    ask(_kbArticles);
  }
  inp.value = '';
}

