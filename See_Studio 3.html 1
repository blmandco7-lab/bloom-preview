function recalcRosterStats() {
  dbGet('studio-roster', function(rosterDocs) {
    rosterDocs = rosterDocs || [];
    if (!rosterDocs.length) {
      var els0 = document.querySelectorAll('#s-roster .sg .stat .sv');
      if (els0[0]) els0[0].textContent = '0';
      if (els0[1]) els0[1].textContent = '0%';
      if (els0[2]) els0[2].textContent = '0';
      if (els0[3]) els0[3].textContent = '$0';
      return;
    }
    var totalReach=0, engSum=0, engCount=0;
    var handles = [];
    rosterDocs.forEach(function(d) {
      totalReach += parseCount(d.followers);
      var e = parseFloat((d.eng||'').replace('%','').trim());
      if (!isNaN(e)) { engSum += e; engCount++; }
      if (d.handle) handles.push(d.handle);
    });
    var avgEng = engCount ? (engSum/engCount).toFixed(1) : '0';
    dbGet('studio-deals', function(dealDocs) {
      dealDocs = dealDocs || [];
      var activeDeals = dealDocs.filter(function(d){ return handles.indexOf(d.creator)!==-1 && d.stage!=='Completed'; }).length;
      dbGet('studio-payments', function(payDocs) {
        payDocs = payDocs || [];
        var now = new Date(); var mo = now.getMonth(); var yr = now.getFullYear();
        var revenueMTD = 0;
        payDocs.forEach(function(d) {
          if (handles.indexOf(d.creator)===-1) return;
          var dt = d._created ? new Date(d._created) : null;
          if (dt && dt.getMonth()===mo && dt.getFullYear()===yr) revenueMTD += parseFloat(d.deal||d.amount||0);
        });
        var els = document.querySelectorAll('#s-roster .sg .stat .sv');
        if (els[0]) els[0].textContent = formatCount(totalReach);
        if (els[1]) els[1].textContent = avgEng+'%';
        if (els[2]) els[2].textContent = activeDeals;
        if (els[3]) els[3].textContent = '$'+formatCount(revenueMTD);
      });
    });
  });
}
