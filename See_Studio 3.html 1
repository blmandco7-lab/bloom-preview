function calcRevenueGap() {
  var target = parseFloat((document.getElementById('rp-target')||{value:400000}).value) || 400000;
  var runRateText = (document.getElementById('rp-runrate')||{textContent:'$310,000'}).textContent;
  var runRate = parseFloat(runRateText.replace(/[^0-9.]/g,'')) || 310000;
  var gap = Math.max(0, target - runRate);
  var gapEl = document.getElementById('rp-gap');
  if (gapEl) gapEl.textContent = '$'+gap.toLocaleString();
  var advice = document.getElementById('rp-advice');
  if (advice) {
    if (gap <= 0) advice.textContent = "You're already at or above this target based on current run rate.";
    else {
      var retainersNeeded = Math.ceil(gap / (3000*12));
      var dealsPerMonth = Math.ceil((gap/12) / 2500);
      advice.textContent = 'To hit $'+(target/1000).toFixed(0)+'K: add '+retainersNeeded+' more retainer client'+(retainersNeeded!==1?'s':'')+' ($3K/mo each) or close '+dealsPerMonth+' additional brand deal'+(dealsPerMonth!==1?'s':'')+' per month averaging $2,500 each.';
    }
  }
}
function recalcRevenueProjection() {
  dbGet(COLS.payments, function(docs) {
    docs = docs || [];
    var now = new Date(); var mo = now.getMonth(); var yr = now.getFullYear();
    var monthRevenue = docs.filter(function(d){ return d.date && new Date(d.date).getMonth()===mo && new Date(d.date).getFullYear()===yr; })
      .reduce(function(s,d){ return s+parseFloat(d.deal||0); }, 0);
    if (!monthRevenue) {
      var els0 = document.querySelectorAll('#s-revenue-projection .sg .stat .sv');
      if (els0[0]) els0[0].textContent = '$0';
      if (els0[3]) els0[3].textContent = '$0';
      var runRateEl0 = document.getElementById('rp-runrate');
      if (runRateEl0) runRateEl0.textContent = '$0';
      return;
    }
    var runRate = monthRevenue * 12;
    var els = document.querySelectorAll('#s-revenue-projection .sg .stat .sv');
    if (els[0]) els[0].textContent = '$'+monthRevenue.toLocaleString();
    if (els[3]) els[3].textContent = '$'+formatCount(runRate);
    var runRateEl = document.getElementById('rp-runrate');
    if (runRateEl) runRateEl.textContent = '$'+runRate.toLocaleString();
    calcRevenueGap();
  });
}
