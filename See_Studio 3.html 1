// ---- Shared contact directory, filtered by what the current role is allowed to message ----
function getContactDirectory(callback) {
  var results = [{ name: 'See (Director)', type: 'Director' }];
  var sources = [function (cb) {
    dbGet('studio-team-members', function (docs) {
      (docs || []).forEach(function (d) { results.push({ name: d.name, type: d.role === 'agentmgr' ? 'Agent Manager' : 'Agent' }); });
      cb();
    });
  }];
  if (currentRole !== 'creator') {
    // Creators can only reach their agent, their agent manager, or the
    // director -- not brands, other creators, or agency partners.
    sources.push(function (cb) { dbGet('studio-roster', function (docs) { (docs || []).forEach(function (d) { if (d.handle) results.push({ name: d.handle, type: 'Creator' }); }); cb(); }); });
    sources.push(function (cb) { dbGet('studio-brand-directory', function (docs) { (docs || []).forEach(function (d) { if (d.name) results.push({ name: d.name, type: 'Brand' }); }); cb(); }); });
    sources.push(function (cb) { dbGet('studio-sub-agencies', function (docs) { (docs || []).forEach(function (d) { if (d.name) results.push({ name: d.name, type: 'Agency' }); }); cb(); }); });
    sources.push(function (cb) { dbGet('studio-saved-contacts', function (docs) { (docs || []).forEach(function (d) { if (d.name) results.push({ name: d.name, type: d.role || 'Contact', id: d.id }); }); cb(); }); });
  }
  var remaining = sources.length;
  sources.forEach(function (fn) { fn(function () { remaining--; if (remaining === 0) callback(results); }); });
}
function openContactPickerModal(onPick) {
  getContactDirectory(function (contacts) {
    var typePill = { Director: 'pgold', 'Agent Manager': 'pg', Agent: 'pg', Creator: 'pb', Brand: 'pgold', Agency: 'pp' };
    var listHtml = contacts.map(function (c, i) {
      return '<div class="ni-item" style="cursor:pointer" onclick="_pickContact('+i+')"><div class="av" style="width:26px;height:26px;font-size:10px">'+(c.name||'?').replace('@','').substring(0,2).toUpperCase()+'</div><div style="flex:1"><div class="ni-name">'+(c.name||'—')+'</div></div><span class="pill '+(typePill[c.type]||'pb')+'" style="font-size:9px">'+c.type+'</span></div>';
    }).join('');
    window._contactPickerList = contacts;
    window._contactPickerOnPick = onPick;
    var addContactBtn = currentRole !== 'creator' ? '<button class="btn-n" style="width:100%;justify-content:center;margin-top:10px;font-size:11px" onclick="openAddSavedContact()"><i class="ti ti-user-plus"></i>Add a new contact</button>' : '';
    showModal({ title: 'Start a conversation', icon: 'address-book', submit: null, customBody:
      '<div style="margin-bottom:10px"><input class="form-input" id="contact-picker-search" placeholder="Search contacts..." oninput="_filterContactPicker(this.value)" style="width:100%"></div>' +
      '<div id="contact-picker-list" style="max-height:320px;overflow-y:auto">' + (listHtml || '<div style="color:var(--text3);font-size:12px;padding:10px">No contacts available.</div>') + '</div>' + addContactBtn
    });
  });
}
function openAddSavedContact() {
  showModal({ title: 'Add a contact', icon: 'user-plus', submit: 'Save contact', desc: 'For anyone outside your creators, brands, or team — a photographer, lawyer, or other outside contact.', fields: [
    { label: 'Name', id: 'name', placeholder: 'Full name or business name' },
    { label: 'Label', id: 'role', placeholder: 'e.g. Photographer, Lawyer, Vendor' },
    { label: 'Email or phone (optional)', id: 'contactInfo', placeholder: 'How to reach them outside the app' }
  ], onSubmit: function (d) {
    dbAdd('studio-saved-contacts', d, function () {
      showToast(d.name + ' added to your contacts');
      openDMCreator();
    });
  }});
}
function _filterContactPicker(q) {
  q = (q || '').toLowerCase();
  var contacts = window._contactPickerList || [];
  var typePill = { Director: 'pgold', 'Agent Manager': 'pg', Agent: 'pg', Creator: 'pb', Brand: 'pgold', Agency: 'pp' };
  var filtered = contacts.map(function (c, i) { return { c: c, i: i }; }).filter(function (o) { return (o.c.name || '').toLowerCase().indexOf(q) !== -1 || (o.c.type || '').toLowerCase().indexOf(q) !== -1; });
  var el = document.getElementById('contact-picker-list');
  if (!el) return;
  el.innerHTML = filtered.map(function (o) {
    var c = o.c;
    return '<div class="ni-item" style="cursor:pointer" onclick="_pickContact('+o.i+')"><div class="av" style="width:26px;height:26px;font-size:10px">'+(c.name||'?').replace('@','').substring(0,2).toUpperCase()+'</div><div style="flex:1"><div class="ni-name">'+(c.name||'—')+'</div></div><span class="pill '+(typePill[c.type]||'pb')+'" style="font-size:9px">'+c.type+'</span></div>';
  }).join('') || '<div style="color:var(--text3);font-size:12px;padding:10px">No matches.</div>';
}
function _pickContact(i) {
  var contact = (window._contactPickerList || [])[i];
  if (!contact) return;
  closeModal();
  if (window._contactPickerOnPick) window._contactPickerOnPick(contact);
}
function openDMCreator(presetHandle){
  if (presetHandle) {
    showModal({ title: 'Message '+presetHandle, icon: 'message-circle', submit: 'Send', fields: [
      { label: 'Message', id: 'msg', type: 'textarea', rows: 5 }
    ], onSubmit: function (d) {
      dbGet('studio-inbox', function (docs) {
        var existing = (docs || []).find(function (t) { return t.name === presetHandle && !t.with; });
        var msg = { from: 'me', text: d.msg, time: new Date().toISOString() };
        if (existing) {
          dbUpdate('studio-inbox', existing.id, { messages: (existing.messages||[]).concat([msg]) }, function () { showToast('Message sent to '+presetHandle); loadMessagingThreads(); });
        } else {
          dbAdd('studio-inbox', { name: presetHandle, role: 'Creator', messages: [msg] }, function () { showToast('Message sent to '+presetHandle); loadMessagingThreads(); });
        }
      });
    }});
    return;
  }
  openContactPickerModal(function (contact) {
    showModal({ title: 'Message '+contact.name, icon: 'message-circle', submit: 'Send', fields: [
      { label: 'Message', id: 'msg', type: 'textarea', rows: 5 }
    ], onSubmit: function (d) {
      dbGet('studio-inbox', function (docs) {
        var existing = (docs || []).find(function (t) { return t.name === contact.name && !t.with; });
        var msg = { from: 'me', text: d.msg, time: new Date().toISOString() };
        if (existing) {
          var messages = (existing.messages || []).concat([msg]);
          dbUpdate('studio-inbox', existing.id, { messages: messages }, function () { showToast('Message sent to '+contact.name); loadMessagingThreads(); });
        } else {
          dbAdd('studio-inbox', { name: contact.name, role: contact.type, messages: [msg] }, function () { showToast('Message sent to '+contact.name); loadMessagingThreads(); });
        }
      });
    }});
  });
}
function loadMessagingThreads() {
  dbGet('studio-inbox', function(docs) {
    var el = document.getElementById('messaging-real-threads');
    if (!el) return;
    docs = docs || [];
    function render(list) {
      if (!list.length) { el.innerHTML=''; return; }
      el.innerHTML = list.map(function(d) {
        var last = (d.messages||[])[d.messages.length-1] || {text:''};
        var initials = (d.name||'?').replace('@','').substring(0,2).toUpperCase();
        return '<div onclick="openRealThread(\''+d.id+'\')" class="msg-thread" data-real-id="'+d.id+'" style="padding:10px 12px;border-bottom:0.5px solid var(--border);cursor:pointer;position:relative">'+
          '<div style="display:flex;align-items:center;gap:8px;margin-bottom:3px"><div class="av" style="width:24px;height:24px;font-size:9px">'+initials+'</div><div style="font-size:12px;font-weight:500;color:var(--text)">'+(d.name||'—')+'</div>'+
          '<button class="del-btn" data-col="studio-inbox" data-id="'+d.id+'" onclick="event.stopPropagation();dbDelBtn(this)" style="margin-left:auto;padding:2px 5px"><i class="ti ti-trash" style="font-size:10px"></i></button></div>'+
          '<div style="font-size:11px;color:var(--text3);padding-left:32px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+(last.text||'')+'</div>'+
        '</div>';
      }).join('');
    }
    if (currentRole === 'agent' && currentUser && currentUser.name) {
      // An agent only sees conversations with creators actually assigned to
      // them -- not the whole agency's messages.
      dbGet('studio-roster', function (roster) {
        var myHandles = (roster||[]).filter(function(r){ return r.assignedAgent === currentUser.name; }).map(function(r){ return r.handle; });
        render(docs.filter(function(d){ return myHandles.indexOf(d.name) !== -1; }));
      });
    } else {
      render(docs);
    }
  });
}
function openRealThread(id) {
  dbGet('studio-inbox', function(docs) {
    var thread = (docs||[]).find(function(d){ return d.id===id; });
    if (!thread) return;
    currentOpenThreadId = id;
    document.querySelectorAll('.msg-thread').forEach(function(t){t.style.background='';});
    var el = document.querySelector('[data-real-id="'+id+'"]'); if (el) el.style.background='var(--navy4)';
    var header = document.getElementById('msg-thread-header');
    var initials = (thread.name||'?').replace('@','').substring(0,2).toUpperCase();
    if (header) header.innerHTML = '<div class="av">'+initials+'</div><div><div style="font-size:13px;font-weight:500;color:var(--text)">'+(thread.name||'—')+'</div><div style="font-size:10px;color:var(--text3)">'+(thread.role||'')+'</div></div>';
    var msgsEl = document.getElementById('msg-thread-messages');
    if (msgsEl) msgsEl.innerHTML = (thread.messages||[]).map(function(m) {
      var mine = m.from==='me';
      var time = m.time ? new Date(m.time).toLocaleString('en-US',{month:'short',day:'numeric',hour:'numeric',minute:'2-digit'}) : '';
      return mine ?
        '<div style="display:flex;gap:8px;justify-content:flex-end"><div style="background:var(--gold-dim);border:0.5px solid var(--gold);border-radius:8px 0 8px 8px;padding:9px 12px;max-width:70%"><div style="font-size:12px;color:var(--text);line-height:1.5">'+m.text+'</div><div style="font-size:9px;color:var(--text4);margin-top:4px">'+time+'</div></div></div>' :
        '<div style="display:flex;gap:8px"><div style="background:var(--navy4);border-radius:0 8px 8px 8px;padding:9px 12px;max-width:70%"><div style="font-size:12px;color:var(--text);line-height:1.5">'+m.text+'</div><div style="font-size:9px;color:var(--text4);margin-top:4px">'+time+'</div></div></div>';
    }).join('');
  });
}
function openMsg(el){ currentOpenThreadId=null; document.querySelectorAll('.msg-thread').forEach(function(t){t.style.background='';}); if(el) el.style.background='var(--navy4)'; }
function sendMsg(){
  var inp=document.getElementById('msgInput'); if(!inp||!inp.value.trim()) return;
  var text = inp.value.trim();
  if (!currentOpenThreadId) { showToast('Select a conversation first, or tap New message to start one', 'info'); return; }
  dbGet('studio-inbox', function(docs) {
    var thread = (docs||[]).find(function(d){ return d.id===currentOpenThreadId; });
    if (!thread) return;
    var messages = thread.messages || [];
    messages.push({from:'me', text:text, time:new Date().toISOString()});
    dbUpdate('studio-inbox', currentOpenThreadId, {messages: messages}, function(){
      inp.value='';
      openRealThread(currentOpenThreadId);
      loadMessagingThreads();
      showToast('Message sent');
    });
  });
}

// ---- Creator's own inbox: supports a separate thread per contact (agent, agent manager, or director) ----
var _myInboxOpenWith = null;
function openCreatorContactPicker() {
  if (!currentUser) { showToast('Sign in with your individual account to message your team.', 'error'); return; }
  openContactPickerModal(function (contact) {
    _myInboxOpenWith = contact.name;
    dbGet('studio-inbox', function (docs) {
      var existing = (docs || []).find(function (t) { return t.name === (currentUser.handle||currentUser.name) && t.with === contact.name; });
      if (!existing) {
        dbAdd('studio-inbox', { name: currentUser.handle||currentUser.name, with: contact.name, role: 'Creator', messages: [] }, function () { loadMyInboxForCreator(); });
      } else {
        loadMyInboxForCreator();
      }
    });
  });
}
function loadMyInboxForCreator() {
  var listEl = document.getElementById('my-inbox-thread-list');
  var headerEl = document.getElementById('my-inbox-header');
  var msgsEl = document.getElementById('my-inbox-messages');
  if (!listEl) return;
  if (!currentUser) {
    listEl.innerHTML = '<div style="padding:16px;text-align:center;color:var(--text3);font-size:11px">Sign in with your individual account to see your messages.</div>';
    return;
  }
  dbGet('studio-inbox', function (docs) {
    var mine = (docs || []).filter(function (d) { return d.name === (currentUser.handle||currentUser.name) && d.with; });
    if (!mine.length) {
      listEl.innerHTML = '<div style="padding:16px;text-align:center;color:var(--text3);font-size:11px">No conversations yet — tap New message</div>';
      if (headerEl) headerEl.innerHTML = 'Select a conversation, or start a new one';
      if (msgsEl) msgsEl.innerHTML = '';
      return;
    }
    if (!_myInboxOpenWith || !mine.some(function(t){return t.with===_myInboxOpenWith;})) _myInboxOpenWith = mine[0].with;
    listEl.innerHTML = mine.map(function (t) {
      var last = (t.messages||[])[t.messages.length-1] || {text:'No messages yet'};
      var active = t.with === _myInboxOpenWith;
      return '<div onclick="openMyInboxThread(\''+t.with.replace(/'/g,"\\'")+'\')" style="padding:10px 12px;border-bottom:0.5px solid var(--border);cursor:pointer;'+(active?'background:var(--navy4)':'')+'"><div style="font-size:12px;font-weight:500;color:var(--text)">'+t.with+'</div><div style="font-size:11px;color:var(--text3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+(last.text||'')+'</div></div>';
    }).join('');
    renderMyInboxThread(mine.find(function(t){return t.with===_myInboxOpenWith;}));
  });
}
function openMyInboxThread(withWho) {
  _myInboxOpenWith = withWho;
  loadMyInboxForCreator();
}
function renderMyInboxThread(thread) {
  var headerEl = document.getElementById('my-inbox-header');
  var msgsEl = document.getElementById('my-inbox-messages');
  if (!thread) return;
  if (headerEl) headerEl.innerHTML = '<div style="font-size:13px;font-weight:500;color:var(--text)">'+thread.with+'</div>';
  if (msgsEl) msgsEl.innerHTML = (thread.messages||[]).length ? (thread.messages||[]).map(function (m) {
    var mine = m.from === 'me';
    var time = m.time ? new Date(m.time).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) : '';
    return mine
      ? '<div style="display:flex;gap:8px;justify-content:flex-end"><div style="background:var(--gold-dim);border:0.5px solid var(--gold);border-radius:8px 0 8px 8px;padding:9px 12px;max-width:70%"><div style="font-size:12px;color:var(--text);line-height:1.5">'+m.text+'</div><div style="font-size:9px;color:var(--text4);margin-top:4px">'+time+'</div></div></div>'
      : '<div style="display:flex;gap:8px"><div style="background:var(--navy4);border-radius:0 8px 8px 8px;padding:9px 12px;max-width:70%"><div style="font-size:12px;color:var(--text);line-height:1.5">'+m.text+'</div><div style="font-size:9px;color:var(--text4);margin-top:4px">'+time+'</div></div></div>';
  }).join('') : '<div style="color:var(--text3);font-size:12px;text-align:center;padding:20px">Say hello!</div>';
}
function sendMyInboxMsg() {
  var inp = document.getElementById('myInboxInput');
  if (!inp || !inp.value.trim() || !currentUser || !_myInboxOpenWith) return;
  var text = inp.value.trim();
  inp.value = '';
  dbGet('studio-inbox', function (docs) {
    var thread = (docs || []).find(function (d) { return d.name === (currentUser.handle||currentUser.name) && d.with === _myInboxOpenWith; });
    if (!thread) return;
    var messages = (thread.messages || []).concat([{ from: 'me', text: text, time: new Date().toISOString() }]);
    dbUpdate('studio-inbox', thread.id, { messages: messages }, function () { loadMyInboxForCreator(); });
  });
}

function loadFTCCompliance() {
  dbGet('studio-content-review', function(docs) {
    docs = docs || [];
    var flagsEl = document.getElementById('ftc-real-flags');
    var tableEl = document.getElementById('ftc-real-table');
    var label = document.getElementById('ftc-example-label');
    if (!docs.length) { if(flagsEl) flagsEl.innerHTML=''; if(tableEl) tableEl.innerHTML=''; _toggleExampleBlock(label, true); return; }
    _toggleExampleBlock(label, false);
    var flagged = docs.filter(function(d){ return !d.ftcOk; });
    if (flagsEl) flagsEl.innerHTML = flagged.map(function(d) {
      return '<div style="margin-bottom:12px;display:flex;align-items:flex-start;gap:9px;padding:12px;border-radius:8px;background:var(--amber-bg);border:0.5px solid var(--amber)" data-id="'+d.id+'"><i class="ti ti-alert-triangle" style="font-size:18px;color:var(--amber);margin-top:1px"></i><div><div style="font-size:13px;font-weight:500;color:var(--text);margin-bottom:3px">FTC flag — '+(d.creator||'—')+' · '+(d.campaign||'')+'</div><div style="font-size:11px;color:var(--text3);line-height:1.5">Sponsored post submitted without #ad or #sponsored disclosure.</div></div><button class="btn-g" style="margin-left:auto;font-size:11px;flex-shrink:0" onclick="remindCreatorFTC(\''+d.id+'\',\''+(d.creator||'').replace(/'/g,"\\'")+'\')"><i class="ti ti-send"></i>Remind creator</button></div>';
    }).join('');
    if (tableEl) tableEl.innerHTML = docs.map(function(d) {
      return '<div class="tr" style="grid-template-columns:2fr 1.5fr 1fr 1fr 1fr 80px" data-id="'+d.id+'"><div style="display:flex;align-items:center;gap:8px"><div class="av">'+(d.creator||'?').replace('@','').substring(0,2).toUpperCase()+'</div><div class="tn">'+(d.creator||'—')+'</div></div><div class="td">'+(d.campaign||'—')+'</div><div><span class="plat tt">'+(d.platform||'—').substring(0,2).toUpperCase()+'</span></div><div class="td">'+(d._created?new Date(d._created).toLocaleDateString('en-US',{month:'short',day:'numeric'}):'—')+'</div><div class="td" style="color:var(--'+(d.ftcOk?'green':'red')+')">'+(d.ftcOk?'#ad present':'Missing #ad')+'</div><div><span class="pill '+(d.ftcOk?'pg':'pr')+'">'+(d.ftcOk?'Clear':'Flagged')+'</span></div></div>';
    }).join('');
  });
}
function openReviewRevision(){showModal({title:'Request revision',icon:'edit',submit:'Send',fields:[{label:'Feedback',id:'fb',type:'textarea',rows:4}],onSubmit:function(d){ showToast('Revision request sent'); }});}
function loadAnalyticsReal() {
  dbGet(COLS.deals, function(deals) {
    dbGet('studio-content-library', function(posts) {
      var el = document.getElementById('analytics-real-table');
      var label = document.getElementById('analytics-example-label');
      posts = posts || [];
      if (posts.length) {
        var totalImp = posts.reduce(function(s,p){ return s+parseFloat(p.impressions||0); }, 0);
        var withEng = posts.filter(function(p){ return p.engagement; });
        var totalEngCount = Math.round(posts.reduce(function(s,p){ return s+(parseFloat(p.impressions||0)*parseFloat(p.engagement||0)/100); }, 0));
        var els = document.querySelectorAll('#s-analytics .sg .stat .sv');
        if (totalImp && els[0]) els[0].textContent = formatCount(totalImp);
        if (totalEngCount && els[2]) els[2].textContent = formatCount(totalEngCount);
      }
      if (!el) return;
      var withBudget = (deals||[]).filter(function(d){ return d.budget && parseFloat(d.budget)>0; });
      var monthSel = document.getElementById('analytics-month-select');
      var monthVal = monthSel ? monthSel.value : 'All time';
      if (monthVal !== 'All time') {
        var parts = monthVal.split(' '); // e.g. "Jun 2026"
        var monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        var mi = monthNames.indexOf(parts[0]); var yr = parseInt(parts[1]);
        withBudget = withBudget.filter(function(d){
          if (!d._created) return false;
          var dt = new Date(d._created);
          return dt.getMonth()===mi && dt.getFullYear()===yr;
        });
      }
      if (!withBudget.length) { el.innerHTML=''; _toggleExampleBlock(label, true); return; }
      _toggleExampleBlock(label, false);
      posts = posts || [];
      el.innerHTML = '<div class="card"><div class="th-row" style="grid-template-columns:2fr 1.5fr 1fr 1fr 1fr 1fr 80px"><div class="th">Campaign</div><div class="th">Creator</div><div class="th">Brand spend</div><div class="th">Impressions</div><div class="th">Engagements</div><div class="th">ROI</div><div class="th">Platform</div></div>'+
        withBudget.map(function(d) {
          var matchPost = posts.filter(function(p){ return p.creator===d.creator && p.brand===d.brand; })[0];
          var impressions = matchPost ? formatCount(parseFloat(matchPost.impressions||0)) : '—';
          var engPct = matchPost ? matchPost.engagement : null;
          var budget = parseFloat(d.budget);
          var roi = matchPost && matchPost.impressions ? (parseFloat(matchPost.impressions)*0.002/budget).toFixed(1)+'×' : '—';
          return '<div class="tr" style="grid-template-columns:2fr 1.5fr 1fr 1fr 1fr 1fr 80px" data-id="'+d.id+'"><div class="tn">'+(d.brand||'—')+'</div><div style="display:flex;align-items:center;gap:6px"><div class="av" style="width:22px;height:22px;font-size:9px">'+(d.creator||'?').replace('@','').substring(0,2).toUpperCase()+'</div><div class="td">'+(d.creator||'—')+'</div></div><div class="td">$'+budget.toLocaleString()+'</div><div class="td">'+impressions+'</div><div class="td">'+(engPct?engPct+'%':'—')+'</div><div class="td" style="color:var(--green)">'+roi+'</div><div class="td">'+(d.platform||'—')+'</div></div>';
        }).join('') + '</div>';
    });
  });
}
function remindCreatorFTC(id, creator) {
  sendSlack('FTC reminder sent to '+creator+' — missing disclosure tag');
  logAuditEvent('FTC reminder sent', 'Reminded '+creator+' to add disclosure', currentRole);
  showToast('Reminder sent to '+creator);
}
var contentFilterState = 'all';
function openSubmitMyContent() {
  if (!(currentUser && currentUser.handle)) { showToast('Sign in with your individual account to submit content.', 'error'); return; }
  showModal({title:'Submit content for review',icon:'file-text',submit:'Submit',fields:[
    {label:'Campaign',id:'campaign',placeholder:'e.g. DripRoom Fashion Week'},
    {label:'Platform',id:'platform',type:'select',options:['TikTok','Instagram','YouTube','X']},
    {label:'Caption draft',id:'caption',type:'textarea',rows:4,placeholder:'Include #ad or #sponsored if this is a paid partnership'}
  ],onSubmit:function(d){
    d.creator = currentUser.handle;
    d.status = 'Pending';
    d.ftcOk = /#ad|#sponsored|#partner/i.test(d.caption||'');
    _contentNeedsDirectorReview(function (needsReview) {
      if (needsReview) d.status = 'Director review';
      dbAdd('studio-content-review', d, function(){ showToast('Content submitted for review'); loadMyContentReview(); });
    });
  }});
}
function loadMyContentReview() {
