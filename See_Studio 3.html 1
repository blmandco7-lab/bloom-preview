    if (platEl) platEl.innerHTML = '<span class="plat tt">' + (d.platform || 'Platform') + ' ' + (d.followers || '—') + '</span>';
    e('cp-reach', d.followers || '—');
    e('cp-eng', eng ? eng + '%' : '—');
    e('cp-eng-note', eng >= 8 ? 'Well above average' : eng >= 4 ? 'Above average' : eng > 0 ? 'Below average' : 'No data yet');
    // Rough estimate only -- roughly $10 per 1,000 followers, scaled up for
    // stronger engagement. Not a real market-rate lookup.
    var rate = Math.round((followers / 1000) * 10 * (1 + eng / 15) / 10) * 10;
    e('cp-rate', rate ? '$' + rate.toLocaleString() : '—');
    // Simple, transparent score: base on engagement rate, not a black box.
