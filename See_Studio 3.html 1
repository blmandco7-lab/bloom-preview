// ── TOAST ──
function showToast(msg, type) {
  var t = document.createElement('div');
  var colors = { success:'#3ddc97', error:'#e0705c', info:'#5a9ee6' };
  var c = colors[type] || colors.success;
  t.style.cssText = 'position:fixed;bottom:24px;right:24px;background:var(--navy2);border:0.5px solid '+c+';color:'+c+';border-radius:8px;padding:10px 16px;font-size:12px;z-index:9999;display:flex;align-items:center;gap:8px;box-shadow:0 4px 20px rgba(0,0,0,.4);font-family:DM Sans,sans-serif';
  t.innerHTML = '<i class="ti ti-check" style="font-size:14px"></i>' + msg;
  document.body.appendChild(t);
  setTimeout(function(){ t.style.opacity='0'; t.style.transition='opacity .3s'; setTimeout(function(){ t.remove(); },300); }, 2800);
}
// Shows the ACTUAL error message on-screen (and keeps it up, unlike a toast)
// so a real bug can be read and reported back precisely, instead of the
// browser's generic "uncaught script error" with no detail.
function _showRealErrorBanner(message) {
  try {
    var existing = document.getElementById('_realErrorBanner');
    if (existing) existing.remove();
    var b = document.createElement('div');
    b.id = '_realErrorBanner';
    b.style.cssText = 'position:fixed;top:0;left:0;right:0;background:#3a1414;border-bottom:2px solid #e0705c;color:#ffb4a8;padding:10px 16px;font-size:12px;z-index:99999;font-family:monospace;display:flex;align-items:flex-start;gap:10px;max-height:40vh;overflow-y:auto';
    b.innerHTML = '<div style="flex:1;white-space:pre-wrap;word-break:break-word">' + message.replace(/</g,'&lt;') + '</div><button onclick="document.getElementById(\'_realErrorBanner\').remove()" style="background:none;border:none;color:#ffb4a8;font-size:16px;cursor:pointer;flex-shrink:0">×</button>';
    document.body.appendChild(b);
  } catch (e) {}
}
window.addEventListener('error', function (event) {
  _showRealErrorBanner('Script error: ' + (event.message || 'unknown') + '\n' + (event.filename ? 'at line ' + event.lineno + ':' + event.colno : ''));
});
window.addEventListener('unhandledrejection', function (event) {
  _showRealErrorBanner('Unhandled promise rejection: ' + (event.reason && event.reason.message ? event.reason.message : event.reason));
});

