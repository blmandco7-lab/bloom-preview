  }
  if (feed) feed.innerHTML = '<div style="padding:20px;color:var(--gold);font-size:12px">Scanning YouTube for ' + niche + ' creators...</div>';
  var queries = {pet:'pet creator influencer',beauty:'beauty skincare influencer',lifestyle:'lifestyle vlog',fitness:'fitness influencer',fashion:'fashion style haul'};
  var q = encodeURIComponent(queries[niche] || niche);
  fetch('https://www.googleapis.com/youtube/v3/search?part=snippet&type=channel&q=' + q + '&maxResults=10&key=' + key)
