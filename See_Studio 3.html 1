function nav(key) {
  try {
    closeModal(); // Defensive: a modal left open while navigating away would sit on
    // top of whatever screen loads next (its backdrop is nearly opaque), making
    // that screen look "blank" until the modal is dismissed or the page reloads.
    closeDelModal(); // Same defensive close for the delete-confirmation modal —
    // it was previously never force-closed on nav, so leaving a delete prompt
    // open and then navigating away (or hitting a screen that re-triggers nav)
    // could leave its near-opaque backdrop stuck on top of the real content.
    var allowedScreens = getEffectiveAllowedScreens(currentRole) || [];
    if (allowedScreens.length && allowedScreens.indexOf(key) === -1) {
      console.warn('Blocked: role "'+currentRole+'" cannot access "'+key+'"');
      showToast('You don\'t have access to that page', 'error');
      key = roleDefaults[currentRole] || key;
      if (allowedScreens.indexOf(key) === -1) return;
    }
    document.querySelectorAll('.screen').forEach(function(s){ s.style.display='none'; s.classList.remove('active'); });
    var t=document.getElementById('s-'+key);
    if(t) { t.style.display='block'; t.classList.add('active'); }
    var _ab3=document.getElementById('appBody'); if(_ab3) _ab3.setAttribute('data-manual-nav','true');
    document.querySelectorAll('.ni').forEach(function(n){ n.classList.toggle('active',n.getAttribute('data-screen')===key); });
    var main=document.getElementById('main'); if(main) main.scrollTop=0;
    closeSidebar();
    if(navHistory[navHistory.length-1]!==key) navHistory.push(key);
    if(navHistory.length>20) navHistory.shift();
    var bb=document.getElementById('backBtn'); if(bb) bb.style.display=navHistory.length>1?'flex':'none';
    try{saveLoginState(currentRole,key);}catch(e2){}
    try{autoLoadScreen(key);}catch(e2){}
    try{universalLoadScreen(key);}catch(e2){}
    try{applyDismissedRows();}catch(e2){}
    try{applySubAgencyIdentity();}catch(e2){}
    try{applyAgencyIdentity();}catch(e2){}
    try{applyCreatorIdentity();}catch(e2){}
    try{applyAgentIdentity();}catch(e2){}
    try{trackScreen(key);}catch(e2){}
  } catch(e) { console.error('nav error:',e); }
}
