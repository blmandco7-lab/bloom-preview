<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>See Studio — See</title>
<!-- Dev-only error banner removed: it exposed raw JS error messages, filenames,
     and line numbers to real users in production. -->
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Playfair+Display:wght@600&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<style>
:root{
  --navy:#08090c;--navy2:#0d0e12;--navy3:#101218;--navy4:#15171e;--navy5:#1c1e26;
  --border:#1c1e26;--border2:#282b35;--gold:#d4af6a;--gold2:#e8c988;
  --gold-dim:rgba(212,175,106,0.14);--gold-dim2:rgba(212,175,106,0.07);
  --accent:#3ddc97;--accent2:#5ce8ab;--accent-dim:rgba(61,220,151,0.14);--accent-dim2:rgba(61,220,151,0.07);
  --text:#e8edf5;--text2:#c4c8d1;--text3:#767b87;--text4:#454955;
  --green:#3ddc97;--green-bg:#0a1712;--red:#e0705c;--red-bg:#170d0a;
  --blue:#5a9ee6;--blue-bg:#0a131c;--amber:#e0b25c;--amber-bg:#171008;
  --purple:#a58af0;--purple-bg:#130f1e;--r8:6px;--r12:12px;
  --sidebar-w:172px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--navy);color:var(--text);height:100vh;height:100dvh;display:flex;flex-direction:column;overflow-y:auto}

/* ── TOPBAR ── */
.topbar{height:44px;background:linear-gradient(180deg,var(--navy3),var(--navy2));border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;padding:0 12px;flex-shrink:0}
.logo{font-family:'Playfair Display',serif;font-size:16px;color:var(--gold);letter-spacing:.3px}
.logo-sub{font-size:8px;color:var(--text4);text-transform:uppercase;letter-spacing:1.5px}
.top-center{display:flex;align-items:center;gap:5px;margin:0 auto}
.role-indicator{display:flex;align-items:center;gap:2px;background:var(--navy3);border-radius:7px;padding:3px 4px;border:1px solid var(--border)}
.role-btn{padding:3px 10px;border-radius:5px;font-size:10px;color:var(--text3);cursor:pointer;transition:all .12s;white-space:nowrap;border:none;background:transparent;font-family:inherit}
.role-btn.active{background:var(--accent);color:var(--navy);font-weight:600}
.top-right{display:flex;align-items:center;gap:6px}
.alert-pill{background:var(--red-bg);border:1px solid var(--red);color:var(--red);border-radius:20px;padding:2px 8px;font-size:10px;cursor:pointer;display:flex;align-items:center;gap:3px;font-weight:600}
.cur-role-badge{background:var(--gold-dim);border:1px solid var(--gold);color:var(--gold);border-radius:20px;padding:2px 9px;font-size:10px;font-weight:500}
.av-top{width:26px;height:26px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:var(--navy);cursor:pointer}

/* ── LAYOUT ── */
.app{display:none;height:100vh;height:100dvh;flex-direction:column;min-height:0}
.body-wrap{display:flex!important;flex-direction:row!important;flex:1;overflow:hidden}

/* ── SIDEBAR ── */
.sidebar{width:var(--sidebar-w);background:linear-gradient(180deg,var(--navy2),var(--navy));border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;flex-shrink:0}
.sidebar::-webkit-scrollbar{width:3px}
.sidebar::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.main{flex:1;overflow-y:auto;background:var(--navy3)}
.main::-webkit-scrollbar{width:4px}
.main::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.nav-grp{padding:10px 0 2px}
.nav-lbl{font-size:8.5px;color:var(--text4);text-transform:uppercase;letter-spacing:1.4px;padding:0 11px 4px;font-weight:600}
.ni{display:flex;align-items:center;gap:7px;padding:6px 11px;font-size:11.5px;color:var(--text3);cursor:pointer;transition:all .1s;border-left:2px solid transparent}
.ni:hover{background:var(--navy4);color:var(--text2)}
.ni.active{background:var(--navy4);color:var(--accent);border-left-color:var(--accent)}
.ni i{font-size:13px;flex-shrink:0}
.ni .bdg{margin-left:auto;background:var(--red);color:#fff;border-radius:10px;padding:1px 5px;font-size:9px;font-weight:700}
.ni .bdg-g{margin-left:auto;background:var(--gold-dim);color:var(--gold);border-radius:10px;padding:1px 5px;font-size:9px}
.sidebar-foot{margin-top:auto;padding:10px 11px;border-top:1px solid var(--border)}
.sf-role{font-size:9.5px;color:var(--text3);margin-bottom:2px}
.sf-name{font-size:11px;color:var(--gold)!important;font-weight:500}

/* ── SCREENS ── */
.screen{display:none;padding:14px 16px}
.screen.active{display:block}
.ph{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px}
.pt{font-family:'Space Grotesk',sans-serif;font-size:19px;font-weight:600;color:var(--text);letter-spacing:-.2px}
.ps{font-size:10.5px;color:var(--text3);margin-top:2px}
.ha{display:flex;gap:6px;align-items:center}

/* ── BUTTONS ── */
.btn-g{background:linear-gradient(135deg,var(--accent2),var(--accent));color:#03150d;border:none;border-radius:7px;padding:6px 13px;font-size:11.5px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:4px;font-family:'DM Sans',sans-serif}
.btn-g:hover{filter:brightness(1.06)}
.btn-n{background:transparent;color:var(--text2);border:1px solid var(--border2);border-radius:6px;padding:5px 12px;font-size:11.5px;cursor:pointer;display:inline-flex;align-items:center;gap:4px;transition:all .12s;font-family:inherit}
.btn-n:hover{border-color:var(--accent);color:var(--accent)}
.btn-r{background:var(--red-bg);color:var(--red);border:1px solid var(--red);border-radius:6px;padding:5px 12px;font-size:11.5px;cursor:pointer;display:inline-flex;align-items:center;gap:4px;font-family:inherit}

/* ── STAT GRIDS ── */
.sg{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:7px;margin-bottom:12px}
.sg3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:7px;margin-bottom:12px}
.sg2{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:7px;margin-bottom:12px}
.stat{background:linear-gradient(160deg,var(--navy4) 0%,var(--navy2) 100%);border:1px solid var(--border);border-radius:var(--r8);padding:12px 13px}
.sl{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.6px;margin-bottom:4px;font-weight:600}
.sv{font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:600;color:var(--text);letter-spacing:-.3px}
.sd{font-size:10px;color:var(--gold);margin-top:2px}
.pipeline{display:flex;flex-wrap:wrap;gap:6px;padding:12px;margin-bottom:12px}
.pipeline-stage{flex:1;min-width:80px;background:var(--navy2);border:1px solid var(--border);border-radius:var(--r8);padding:10px 8px;text-align:center;cursor:pointer;transition:border-color .15s}
.pipeline-stage:hover{border-color:var(--accent)}
.pipeline-stage.active-stage{border-color:var(--accent);background:var(--accent-dim)}
.stage-count{font-size:20px;font-weight:600;color:var(--text);margin-bottom:2px}
.stage-label{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.4px}
.sd.g{color:var(--green)}.sd.r{color:var(--red)}

/* ── CARDS & TABLES ── */
.card{background:linear-gradient(165deg,var(--navy3) 0%,var(--navy2) 100%);border:1px solid var(--border);border-radius:var(--r12);overflow:hidden;margin-bottom:10px;box-shadow:0 8px 24px -12px rgba(0,0,0,.5)}
.ch{padding:8px 12px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.ct{font-size:9.5px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.6px}
.th-row{display:grid;padding:6px 12px;border-bottom:1px solid var(--border)}
.th{font-size:9.5px;color:var(--text4);text-transform:uppercase;letter-spacing:.4px;font-weight:600}
.tr{display:grid;padding:8px 12px;border-bottom:1px solid var(--navy3);align-items:center;cursor:pointer;transition:background .1s}
.tr:hover{background:var(--navy4)}
.tr:last-child{border-bottom:none}
.td{font-size:11.5px;color:var(--text2)}
.tn{font-size:12px;color:var(--text);font-weight:500}
.ts-{font-size:10px;color:var(--text3)}
.av{width:26px;height:26px;border-radius:50%;background:var(--navy5);display:flex;align-items:center;justify-content:center;font-size:9.5px;font-weight:600;color:var(--gold);flex-shrink:0}
.av-sq{width:28px;height:28px;border-radius:6px;background:var(--navy5);display:flex;align-items:center;justify-content:center;font-size:9.5px;font-weight:600;color:var(--gold);flex-shrink:0}
.av-lg{width:46px;height:46px;border-radius:50%;background:var(--navy5);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;color:var(--gold);flex-shrink:0;border:2px solid var(--gold)}

/* ── PILLS ── */
.pill{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:20px;font-size:10px;font-weight:500}
.pg{background:var(--green-bg);color:var(--green);border:1px solid var(--green)}
.pr{background:var(--red-bg);color:var(--red);border:1px solid var(--red)}
.pa{background:var(--amber-bg);color:var(--amber);border:1px solid var(--amber)}
.pb{background:var(--blue-bg);color:var(--blue);border:1px solid var(--blue)}
.pp{background:var(--purple-bg);color:var(--purple);border:1px solid var(--purple)}
.pgold{background:var(--gold-dim);color:var(--gold);border:1px solid var(--gold)}

/* ── PLATFORM TAGS ── */
.plats{display:flex;gap:3px;flex-wrap:wrap}
.plat{padding:2px 5px;border-radius:4px;font-size:8.5px;font-weight:700;text-transform:uppercase}
.tt{background:#1a0a12;color:#ff2d78;border:1px solid #ff2d78}
.ig{background:#1a0a10;color:#e1306c;border:1px solid #e1306c}
.yt{background:#1a0808;color:#ff4444;border:1px solid #ff4444}
.xp{background:#0a0a0a;color:#aaa;border:1px solid #444}
.fb{background:#081428;color:#4267B2;border:1px solid #4267B2}
.sc{background:#0a1008;color:#FFFC00;border:1px solid #FFFC00}
.kk{background:#061a08;color:#53fc18;border:1px solid #53fc18}
.tw{background:#100816;color:#9146ff;border:1px solid #9146ff}

/* ── LAYOUT HELPERS ── */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
.three-col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:10px}
.panel{background:linear-gradient(165deg,var(--navy3) 0%,var(--navy2) 100%);border:1px solid var(--border);border-radius:var(--r12);padding:12px;box-shadow:0 8px 24px -14px rgba(0,0,0,.45)}
.pnl-t{font-size:9.5px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px}

/* ── ALERTS ── */
.al{display:flex;align-items:flex-start;gap:8px;padding:9px 10px;border-radius:7px;margin-bottom:5px;border:1px solid}
.al.danger{background:var(--red-bg);border-color:var(--red)}
.al.warn{background:var(--amber-bg);border-color:var(--amber)}
.al.info{background:var(--blue-bg);border-color:var(--blue)}
.al.succ{background:var(--green-bg);border-color:var(--green)}
.al-icon{font-size:13px;flex-shrink:0;margin-top:1px}
.al-body{flex:1}
.al-title{font-size:11.5px;font-weight:500;color:var(--text)}
.al-sub{font-size:10.5px;color:var(--text3);margin-top:1px;line-height:1.5}
.al-time{font-size:10px;color:var(--text4);flex-shrink:0}

/* ── MISSIONS ── */
.mis{background:var(--navy3);border:1px solid var(--border);border-radius:7px;padding:10px 11px;margin-bottom:6px}
.mis-ttl{font-size:11.5px;font-weight:500;color:var(--text);margin-bottom:2px}
.mis-desc{font-size:10.5px;color:var(--text3);line-height:1.5;margin-bottom:6px}
.bar-wrap{background:var(--navy5);border-radius:3px;height:3px;overflow:hidden;margin-bottom:4px}
.bar{height:3px;background:var(--accent);border-radius:3px}
.mis-foot{display:flex;align-items:center;justify-content:space-between}

/* ── LIST ITEMS ── */
.li{display:flex;align-items:flex-start;gap:7px;margin-bottom:7px}
.li i{font-size:12px;color:var(--gold);flex-shrink:0;margin-top:1px}
.li-txt{font-size:10.5px;color:var(--text2);line-height:1.5;flex:1}
.li-time{font-size:9.5px;color:var(--text4);flex-shrink:0}
.ni-item{display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--border)}
.ni-item:last-child{border-bottom:none}
.ni-name{font-size:11.5px;color:var(--text);font-weight:500}
.ni-meta{font-size:10px;color:var(--text3);margin-top:1px}

/* ── CONTENT CARDS ── */
.ccard{background:var(--navy2);border:1px solid var(--border);border-radius:var(--r12);padding:12px;margin-bottom:8px}
.split-bdg{background:var(--gold-dim);border:1px solid var(--gold);border-radius:5px;padding:2px 8px;font-size:9.5px;color:var(--gold)}

/* ── GRID VARIANTS ── */
.mg{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:6px;margin-bottom:10px}
.mg2{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:6px;margin-bottom:10px}
.met{background:var(--navy3);border-radius:7px;padding:9px 10px}
.ml{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.4px;margin-bottom:2px;font-weight:600}
.mv{font-size:12.5px;font-weight:500;color:var(--text)}
.md{font-size:9.5px;color:var(--green);margin-top:1px}

/* ── SCORE RING ── */
.score-ring{width:48px;height:48px;border-radius:50%;border:2.5px solid var(--gold);display:flex;align-items:center;justify-content:center;flex-direction:column;flex-shrink:0}
.sn{font-size:15px;font-weight:600;color:var(--gold)}
.sl2{font-size:7.5px;color:var(--text3)}

/* ── CONFIG ── */
.cfg{background:var(--navy3);border-radius:7px;padding:9px 11px;margin-bottom:6px}
.cfg-lbl{font-size:9.5px;color:var(--text3);text-transform:uppercase;letter-spacing:.4px;margin-bottom:5px}
.cfg-row{display:flex;align-items:center;gap:8px}
.cfg-val{font-size:11.5px;color:var(--gold);font-weight:500;min-width:34px;text-align:right}
input[type=range]{flex:1;accent-color:var(--gold)}

/* ── TOGGLE ── */
.tog-wrap{display:flex;align-items:center;gap:7px}
.tog{width:30px;height:17px;border-radius:9px;position:relative;cursor:pointer;flex-shrink:0;transition:background .2s}
.tog.on{background:var(--accent)}.tog.off{background:var(--navy5)}
.tog-dot{width:11px;height:11px;border-radius:50%;background:var(--navy);position:absolute;top:3px;transition:left .15s}
.tog.on .tog-dot{left:16px}.tog.off .tog-dot{left:3px}
.tog-lbl{font-size:11.5px;color:var(--text)}

/* ── ACTION ITEMS ── */
.act-item{display:flex;align-items:center;gap:8px;padding:8px 10px;background:var(--navy3);border-radius:7px;margin-bottom:5px;cursor:pointer;transition:background .1s}
.act-item:hover{background:var(--navy4)}
.ck{width:15px;height:15px;border-radius:3px;border:1px solid var(--border2);flex-shrink:0;display:flex;align-items:center;justify-content:center}
.ck.done{background:var(--accent);border-color:var(--accent)}
.act-txt{font-size:11.5px;color:var(--text);flex:1}

/* ── POLICY BOX ── */
.policy{background:var(--red-bg);border:1px solid var(--red);border-radius:7px;padding:10px 12px;margin-bottom:10px}
.policy-t{font-size:11.5px;font-weight:500;color:var(--red);display:flex;align-items:center;gap:5px;margin-bottom:4px}
.policy-b{font-size:10.5px;color:var(--text2);line-height:1.6}

/* ── NOTICE ── */
.notice{background:var(--gold-dim2);border:1px solid var(--gold);border-radius:7px;padding:9px 11px;margin-bottom:10px;font-size:10.5px;color:var(--gold);display:flex;align-items:flex-start;gap:7px;line-height:1.5}
.notice i{flex-shrink:0;margin-top:1px}

/* ── DIRECTOR BOX ── */
.dir-box{background:var(--navy2);border:1px solid var(--gold);border-radius:var(--r12);padding:12px;margin-bottom:8px}
.dir-t{font-size:11.5px;font-weight:500;color:var(--gold);margin-bottom:8px;display:flex;align-items:center;gap:5px}
.lock-bdg{background:var(--gold-dim);border:1px solid var(--gold);border-radius:20px;padding:1px 6px;font-size:9px;color:var(--gold);margin-left:auto}

/* ── SECTIONS ── */
.bsec{margin-bottom:12px}
.bsec-t{font-size:9.5px;color:var(--gold);text-transform:uppercase;letter-spacing:1px;margin-bottom:7px;display:flex;align-items:center;gap:5px}
.bsec-t::after{content:'';flex:1;height:1px;background:var(--border);display:block}

/* ── PLATFORM TABS ── */
.plat-tabs{display:flex;gap:2px;background:var(--navy2);border:1px solid var(--border);border-radius:7px;padding:3px;margin-bottom:10px;flex-wrap:wrap}
.ptab{padding:4px 9px;border-radius:5px;font-size:10.5px;color:var(--text3);cursor:pointer;transition:all .12s;display:flex;align-items:center;gap:3px}
.ptab.active{background:var(--accent);color:var(--navy);font-weight:600}

/* ── AGENCY PORTAL ── */
.agency-portal-wrap{background:var(--navy2);border:1px solid var(--border);border-radius:var(--r12);padding:0;overflow:hidden}
.agency-portal-header{background:var(--gold);padding:12px 14px;display:flex;align-items:center;gap:9px}
.agency-portal-title{font-size:14px;font-weight:600;color:var(--navy);font-family:'Playfair Display',serif}
.agency-portal-body{padding:14px}

/* ── MESSAGING ── */
.msg-thread:hover{background:var(--navy4)!important}.active-thread{background:var(--navy4)!important}

/* ── DELETE BTN ── */
.del-btn{background:var(--red-bg);border:1px solid var(--red);color:var(--red);border-radius:5px;padding:3px 6px;font-size:12px;cursor:pointer;transition:all .12s;flex-shrink:0}
.del-btn:hover{background:var(--red);color:#fff}

/* ── DELETE MODAL ── */
.del-modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:1000}
.del-modal{background:var(--navy2);border:1px solid var(--red);border-radius:var(--r12);padding:22px;width:300px;text-align:center}

/* ── BOT CARDS ── */
.bot-card{background:var(--navy2);border:1px solid var(--border);border-radius:var(--r12);padding:12px;margin-bottom:8px}
.bot-header{display:flex;align-items:center;gap:9px;margin-bottom:8px}
.bot-icon{width:34px;height:34px;border-radius:7px;background:var(--navy3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:17px;color:var(--gold);flex-shrink:0}
.bot-name{font-size:12.5px;font-weight:500;color:var(--text)}
.bot-desc{font-size:10.5px;color:var(--text3);line-height:1.6;margin-bottom:9px}
.bot-status-dot{width:7px;height:7px;border-radius:50%;margin-left:auto;flex-shrink:0}
.bot-status-dot.on{background:var(--green)}
.bot-status-dot.off{background:var(--text4)}

/* ── FORMS ── */
.form-field{margin-bottom:10px}
.form-label{display:block;font-size:9.5px;color:var(--text3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:5px;font-weight:600}
.form-input{width:100%;background:var(--navy3);border:1px solid var(--border2);border-radius:6px;padding:8px 10px;font-size:12px;color:var(--text);font-family:'DM Sans',sans-serif;outline:none;transition:border-color .15s}
.form-input:focus{border-color:var(--accent)}
.form-textarea{width:100%;background:var(--navy3);border:1px solid var(--border2);border-radius:6px;padding:8px 10px;font-size:12px;color:var(--text);font-family:'DM Sans',sans-serif;outline:none;resize:vertical;transition:border-color .15s}
.form-textarea:focus{border-color:var(--accent)}
.form-select{width:100%;background:var(--navy3);border:1px solid var(--border2);border-radius:6px;padding:7px 10px;font-size:12px;color:var(--text);font-family:'DM Sans',sans-serif;outline:none}

/* ── ACCESS CODES ── */
