function calcPredictiveROI() {
  var tier=(document.getElementById('pred-tier')||{value:'gold'}).value;
  var platform=(document.getElementById('pred-platform')||{value:'tiktok'}).value;
  var category=(document.getElementById('pred-category')||{value:'fashion'}).value;
  var deal=parseFloat((document.getElementById('pred-deal')||{value:3000}).value)||3000;
  var posts=parseInt((document.getElementById('pred-posts')||{value:3}).value)||3;
  var impBase={bronze:[30000,80000],silver:[80000,300000],gold:[300000,800000],platinum:[500000,2000000]};
  var tierImp=impBase[tier]||impBase.gold;
  var pm={tiktok:1.4,instagram:1.0,youtube:1.2,mixed:1.3}[platform]||1.0;
  var catEng={fashion:[5.5,8.5],beauty:[4.5,7.5],fitness:[6.0,9.5],tech:[3.5,6.5],food:[5.0,8.0],pet:[7.0,11.0],lifestyle:[5.0,8.0]};
  var eng=catEng[category]||catEng.lifestyle;
  var impL=Math.round(tierImp[0]*pm*posts/100000)*100000, impH=Math.round(tierImp[1]*pm*posts/100000)*100000;
  var emvL=Math.round(impL*.0038),emvH=Math.round(impH*.0060);
  var priceL=Math.round(emvL/4.5/100)*100, priceH=Math.round(emvH/3.2/100)*100;
  function fP(n){return n>=1000000?(n/1000000).toFixed(1)+'M':n>=1000?(n/1000).toFixed(0)+'K':String(n);}
  var mp={'pred-impressions':fP(impL)+' – '+fP(impH),'pred-eng-rate':eng[0].toFixed(1)+'% – '+eng[1].toFixed(1)+'%','pred-emv':'$'+emvL.toLocaleString()+' – $'+emvH.toLocaleString(),'pred-roi':(emvL/deal).toFixed(1)+'x – '+(emvH/deal).toFixed(1)+'x','pred-price':'$'+priceL.toLocaleString()+' – $'+priceH.toLocaleString()};
  for(var id in mp){var el=document.getElementById(id);if(el)el.textContent=mp[id];}
}
