    dbUpdate('studio-casting-applications', appId, { status: 'Matched' }, function () {
      showToast(a.creator+' matched ✓');
      dbGet('studio-inbox', function (docs) {
        var thread = (docs || []).find(function (d) { return d.name === a.creator; });
        var msg = { from: 'me', text: "Good news — you've been matched to the "+(a.brand||'')+' deal! Your agent will be in touch with next steps.', time: new Date().toISOString() };
