function recalcAgentDashStats() {
  if (!(currentUser && currentUser.role==='agent' && currentUser.name)) return; // shared-code agent login has no identity to scope stats to
  dbGet(COLS.deals, function(deals) {
    deals = deals || [];
    var myDeals = deals.filter(function(d){ return d.agent===currentUser.name; });
    var activeDeals = myDeals.filter(function(d){ return d.stage!=='Completed'; });
    var myCreators = {};
    myDeals.forEach(function(d){ if (d.creator) myCreators[d.creator]=true; });
    var els = document.querySelectorAll('#s-agent-dash .sg .stat .sv');
    if (els[0]) els[0].textContent = Object.keys(myCreators).length;
    if (els[1]) els[1].textContent = activeDeals.length;
    // Note: deals don't track a per-deal commission amount, so "My revenue" is
    // left as an illustrative figure rather than computing something we can't
    // back with real data.
  });
}
