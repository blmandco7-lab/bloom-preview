    if (alertSubEls[0]) alertSubEls[0].textContent = urgent+' urgent';
  }

  dbGet('studio-contracts', function(docs) {
    var now = new Date();
    (docs||[]).forEach(function(d) {
      if (!d.end) return;
      var days = Math.round((new Date(d.end) - now) / 86400000);
      if (days >= 0 && days <= 14) {
        alerts.push({severity: days<=3?0:1, cls: days<=3?'danger':'warn', icon:'ti-file-text', color: days<=3?'--red':'--amber',
          title: 'Contract expiring — '+(d.party||'Unknown'), sub: 'Expires in '+days+' day'+(days===1?'':'s')+'. Renew or let lapse.'});
      }
    });
    checkDone();
  });

  dbGet('studio-invoices', function(docs) {
    var now = new Date();
    (docs||[]).forEach(function(d) {
      var isOverdue = d.status==='Overdue' || (d.due && new Date(d.due) < now && d.status!=='Paid');
      if (isOverdue) {
        alerts.push({severity: 0, cls:'danger', icon:'ti-alert-circle', color:'--red',
          title: 'Invoice overdue — '+(d.to||'Unknown'), sub: '$'+parseFloat(d.amount||0).toLocaleString()+' past due. Follow up needed.'});
      }
    });
    checkDone();
  });

  dbGet('studio-w9s', function(docs) {
    (docs||[]).forEach(function(d) {
      if (d.status!=='On file') {
        alerts.push({severity: 2, cls:'warn', icon:'ti-file-description', color:'--amber',
          title: 'W-9 outstanding — '+(d.name||'Unknown'), sub: 'Required before any payment over $600/year.'});
      }
    });
    checkDone();
  });
