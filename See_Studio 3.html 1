var calState = (function(){ var d=new Date(); return {year:d.getFullYear(), month:d.getMonth()}; })();
function calNavMonth(delta){
  calState.month += delta;
  if (calState.month > 11) { calState.month = 0; calState.year++; }
  if (calState.month < 0) { calState.month = 11; calState.year--; }
  loadCalendarEvents();
}
function renderCalendarGrid(events){
  var grid = document.getElementById('calendar-grid');
  var label = document.getElementById('calendar-month-label');
  if (!grid) return;
  var monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  if (label) label.textContent = monthNames[calState.month] + ' ' + calState.year;
  var typeColor = {'Campaign deadline':'gold','Payment date':'green','Contract renewal':'red','Meeting':'blue','Content due':'gold','Tax deadline':'red'};
  var byDay = {};
  (events||[]).forEach(function(ev){
    if (!ev.date) return;
    var dt = new Date(ev.date+'T00:00');
    if (dt.getFullYear() === calState.year && dt.getMonth() === calState.month) {
      var day = dt.getDate();
      (byDay[day] = byDay[day] || []).push(ev);
    }
  });
  var firstDow = new Date(calState.year, calState.month, 1).getDay();
  var daysInMonth = new Date(calState.year, calState.month + 1, 0).getDate();
  var today = new Date();
  var isCurrentMonth = today.getFullYear() === calState.year && today.getMonth() === calState.month;
  var html = '';
  for (var i = 0; i < firstDow; i++) {
    html += '<div style="background:var(--navy3);border-radius:6px;padding:8px 6px;text-align:center;font-size:11px;color:var(--text4)"></div>';
  }
  for (var day = 1; day <= daysInMonth; day++) {
    var dayEvents = byDay[day];
    var isToday = isCurrentMonth && today.getDate() === day;
    var style = 'background:var(--navy3);border-radius:6px;padding:8px 6px;text-align:center;font-size:11px;color:var(--text2)';
    var title = '';
    if (dayEvents && dayEvents.length) {
      var color = typeColor[dayEvents[0].type] || 'blue';
      style = 'background:var(--'+color+'-bg,transparent);border:0.5px solid var(--'+color+');border-radius:6px;padding:8px 6px;text-align:center;font-size:11px;color:var(--'+color+');cursor:pointer';
      title = dayEvents.map(function(e){return e.name;}).join(', ').replace(/"/g,'&quot;');
    }
    if (isToday) style = 'background:var(--gold);border-radius:6px;padding:8px 6px;text-align:center;font-size:11px;color:var(--navy);font-weight:700;cursor:pointer';
    html += '<div style="'+style+'"'+(title?' title="'+title+'"':'')+'>'+day+'</div>';
  }
  grid.innerHTML = html;
}
function loadCalendarEvents() {
  dbGet('studio-calendar', function(docs) {
    renderCalendarGrid(docs||[]);
    var el = document.getElementById('calendar-real-events');
    var label = document.getElementById('calendar-example-label');
    if (!el) return;
    docs = (docs||[]).filter(function(d){ return d.name && d.date; }); // only real "Add event" entries, not availability blocks etc.
    if (!docs.length) { el.innerHTML=''; _toggleExampleBlock(label, true); return; }
    _toggleExampleBlock(label, false);
    var typeColor = {'Campaign deadline':'gold','Payment date':'green','Contract renewal':'red','Meeting':'blue','Content due':'gold','Tax deadline':'red'};
    el.innerHTML = docs.map(function(d) {
      var color = typeColor[d.type] || 'blue';
      var dateLabel = d.date ? new Date(d.date+'T00:00').toLocaleDateString('en-US',{month:'short',day:'numeric'}) : '';
      return '<div class="cal-event-card" style="background:var(--'+color+'-bg,transparent);border:0.5px solid var(--border);border-left:3px solid var(--'+color+');border-radius:6px;padding:10px 12px;margin-bottom:7px" data-id="'+d.id+'">'+
        '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:3px"><div style="font-size:12px;font-weight:500;color:var(--text)">'+(d.name||'Untitled')+'</div><span class="pill" style="color:var(--'+color+')">'+dateLabel+'</span></div>'+
        '<div style="font-size:11px;color:var(--text3)">'+(d.who?d.who+' · ':'')+(d.type||'')+(d.notes?' · '+d.notes:'')+'</div>'+
        '<button class="del-btn" data-col="studio-calendar" data-id="'+d.id+'" onclick="dbDelBtn(this)" style="margin-top:6px;padding:2px 6px"><i class="ti ti-trash" style="font-size:10px"></i></button>'+
