function loadProfitLossReal() {
  dbGet(COLS.payments, function(payDocs) {
    dbGet(COLS.expenses, function(expDocs) {
      var el = document.getElementById('pl-real-note');
      payDocs = payDocs || []; expDocs = expDocs || [];
      if (!payDocs.length && !expDocs.length) { if(el) el.innerHTML=''; return; }
      var now = new Date(); var mo = now.getMonth(); var yr = now.getFullYear();
      function inMonth(dateStr) { if (!dateStr) return false; var d = new Date(dateStr); return d.getMonth()===mo && d.getFullYear()===yr; }
      function inYear(dateStr) { if (!dateStr) return false; return new Date(dateStr).getFullYear()===yr; }
      var monthPay = payDocs.filter(function(d){ return inMonth(d.date); });
      var yearPay = payDocs.filter(function(d){ return inYear(d.date); });
      var monthExp = expDocs.filter(function(d){ return inMonth(d.date); });
      var yearExp = expDocs.filter(function(d){ return inYear(d.date); });
      var mRevenue = monthPay.reduce(function(s,d){return s+parseFloat(d.deal||0);},0);
      var mPayouts = monthPay.reduce(function(s,d){return s+parseFloat(d.payout||0);},0);
      var mCommission = monthPay.reduce(function(s,d){return s+parseFloat(d.commission||0);},0);
      var mExpenses = monthExp.reduce(function(s,d){return s+parseFloat(d.amount||0);},0);
      var mNet = mRevenue - mPayouts - mCommission - mExpenses;
      var yRevenue = yearPay.reduce(function(s,d){return s+parseFloat(d.deal||0);},0);
      var yPayouts = yearPay.reduce(function(s,d){return s+parseFloat(d.payout||0);},0);
      var yCommission = yearPay.reduce(function(s,d){return s+parseFloat(d.commission||0);},0);
      var yExpenses = yearExp.reduce(function(s,d){return s+parseFloat(d.amount||0);},0);
      var yNet = yRevenue - yPayouts - yCommission - yExpenses;
      var e = function(id,v){ var x=document.getElementById(id); if(x) x.textContent=v; };
      if (monthPay.length || monthExp.length) {
        e('pl-month-label', now.toLocaleDateString('en-US',{month:'long',year:'numeric'})+' summary');
        e('pl-revenue', '$'+mRevenue.toLocaleString());
        e('pl-payouts', '-$'+mPayouts.toLocaleString());
        e('pl-commission', '-$'+mCommission.toLocaleString());
        e('pl-expenses', '-$'+mExpenses.toLocaleString());
        e('pl-net', (mNet<0?'-':'')+'$'+Math.abs(mNet).toLocaleString());
        var margin = mRevenue ? ((mNet/mRevenue)*100).toFixed(1) : '0';
        e('pl-margin-line', 'Profit margin: '+margin+'% · Agency cut before expenses: $'+(mRevenue-mPayouts).toLocaleString());
      }
      if (yearPay.length || yearExp.length) {
        e('pl-ytd-year', String(yr));
        e('pl-ytd-revenue', '$'+formatCount(yRevenue));
        e('pl-ytd-expenses', '$'+formatCount(yExpenses));
        e('pl-ytd-payouts', '$'+formatCount(yPayouts));
        e('pl-ytd-net', (yNet<0?'-':'')+'$'+formatCount(Math.abs(yNet)));
      }
      if (el) el.innerHTML = '<div class="notice"><i class="ti ti-receipt"></i>The summary above is calculated from your real Payment records ('+payDocs.length+' logged) and Expense tracker ('+expDocs.length+' logged).</div>';

      // Monthly trend — real net profit for each of the last 6 months, if enough data exists
      var barsEl = document.getElementById('pl-trend-bars');
      var labelsEl = document.getElementById('pl-trend-labels');
      if (barsEl && labelsEl && (payDocs.length || expDocs.length)) {
        var months = [];
        for (var i=5;i>=0;i--) {
          var d = new Date(now.getFullYear(), now.getMonth()-i, 1);
          months.push({m: d.getMonth(), y: d.getFullYear(), label: d.toLocaleDateString('en-US',{month:'short'})});
        }
        var monthNets = months.map(function(mObj) {
          var mp = payDocs.filter(function(p){ return p.date && new Date(p.date).getMonth()===mObj.m && new Date(p.date).getFullYear()===mObj.y; });
          var me = expDocs.filter(function(p){ return p.date && new Date(p.date).getMonth()===mObj.m && new Date(p.date).getFullYear()===mObj.y; });
          var rev = mp.reduce(function(s,p){return s+parseFloat(p.deal||0);},0);
          var payout = mp.reduce(function(s,p){return s+parseFloat(p.payout||0);},0);
          var comm = mp.reduce(function(s,p){return s+parseFloat(p.commission||0);},0);
          var exp = me.reduce(function(s,p){return s+parseFloat(p.amount||0);},0);
          return rev - payout - comm - exp;
        });
        var hasAnyData = monthNets.some(function(n){ return n !== 0; });
        if (hasAnyData) {
          var maxAbs = Math.max.apply(null, monthNets.map(function(n){ return Math.abs(n); }).concat([1]));
          barsEl.innerHTML = monthNets.map(function(n) {
            var pct = Math.max(4, Math.round((Math.abs(n)/maxAbs)*100));
            var color = n>=0 ? 'var(--green)' : 'var(--red)';
            return '<div style="flex:1;background:'+color+';border-radius:2px 2px 0 0;height:'+pct+'%" title="$'+Math.round(n).toLocaleString()+'"></div>';
          }).join('');
          labelsEl.innerHTML = months.map(function(mObj){ return '<div style="flex:1;font-size:9px;color:var(--text4);text-align:center">'+mObj.label+'</div>'; }).join('');
        }
      }
    });
  });
}
