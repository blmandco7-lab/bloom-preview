function runYouTubeScout() {
  var nicheEl = document.getElementById('scout-niche-filter');
  var niche = nicheEl ? nicheEl.value : 'pet';
  var feed = document.getElementById('scout-feed-results');
  var key = '';
  try { key = localStorage.getItem('bloom_yt_key') || ''; } catch(e) {}
  if (!key) {
    if (feed) {
      feed.innerHTML = '<div style="padding:28px;text-align:center"><p style="color:var(--amber);font-size:13px;margin-bottom:8px">YouTube API key needed</p><p style="color:var(--text3);font-size:11px;margin-bottom:16px">Add your key in Integrations first.</p><button class="btn-g" id="scout-integ-link">Go to Integrations</button></div>';
      var btn = document.getElementById('scout-integ-link');
