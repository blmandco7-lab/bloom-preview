  var canDelete = (currentRole === 'director');

  function renderArticles(extra) {
    var all = _kbArticles.concat(extra || []);
    var visible = _kbVisibleSections();
    all = all.filter(function (a) { return visible.indexOf(a.section || 'General') !== -1; });
    if (!all.length) {
      el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--text3);font-size:12px">No articles yet. Tap Add article to get started.</div>';
      return;
    }
