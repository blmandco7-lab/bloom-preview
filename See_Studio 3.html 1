function calcTaxEstimate() {
  var profit=parseFloat((document.getElementById('tax-profit')||{value:27600}).value)||27600;
  var structure = (document.getElementById('tax-structure')||{value:'LLC (single member)'}).value;
  var state = (document.getElementById('tax-state')||{value:'California'}).value;
  var e=function(id,v){var el=document.getElementById(id);if(el)el.textContent=v;};
  var se=0, fed=0, sePct=0, fedPct=22;
  if (structure==='S-Corp') {
    // Simplified: assume reasonable owner salary isn't separately modeled here — distributions aren't subject to SE tax
    sePct = 0; se = 0; fed = Math.round(profit*0.22);
  } else if (structure==='C-Corp') {
    // Flat corporate rate, no personal SE tax on retained profit
    sePct = 0; se = 0; fedPct = 21; fed = Math.round(profit*0.21);
  } else {
    // Sole proprietor / single-member LLC — pass-through, full SE tax applies
    sePct = 15.3; se = Math.round(profit*0.153); fed = Math.round(profit*0.22);
  }
  var STATE_TAX_RATES = {
    'Alabama':0.05,'Alaska':0,'Arizona':0.025,'Arkansas':0.039,'California':0.093,'Colorado':0.044,'Connecticut':0.0699,'Delaware':0.066,'Florida':0,'Georgia':0.0539,'Hawaii':0.11,'Idaho':0.058,'Illinois':0.0495,'Indiana':0.03,'Iowa':0.038,'Kansas':0.0558,'Kentucky':0.04,'Louisiana':0.03,'Maine':0.0715,'Maryland':0.0575,'Massachusetts':0.05,'Michigan':0.0425,'Minnesota':0.0985,'Mississippi':0.044,'Missouri':0.047,'Montana':0.059,'Nebraska':0.0584,'Nevada':0,'New Hampshire':0,'New Jersey':0.0637,'New Mexico':0.059,'New York':0.0685,'North Carolina':0.045,'North Dakota':0.025,'Ohio':0.035,'Oklahoma':0.0475,'Oregon':0.099,'Pennsylvania':0.0307,'Rhode Island':0.0599,'South Carolina':0.062,'South Dakota':0,'Tennessee':0,'Texas':0,'Utah':0.0465,'Vermont':0.0875,'Virginia':0.0575,'Washington':0,'Washington DC':0.0895,'West Virginia':0.0482,'Wisconsin':0.0765,'Wyoming':0
  };
  var stateRate = STATE_TAX_RATES.hasOwnProperty(state) ? STATE_TAX_RATES[state] : 0.05;
  var stateTax = Math.round(profit*stateRate);
  var total = se+fed+stateTax;
  e('tax-se-label', 'Self-employment tax ('+sePct+'%)');
  e('tax-fed-label', (structure==='C-Corp'?'Corporate tax (est. ':'Federal income tax (est. ')+fedPct+'%)');
  e('tax-state-label', 'State tax ('+state+(stateRate?', approx. '+(stateRate*100).toFixed(1)+'% top rate':', no state income tax')+')');
  e('tax-se','$'+se.toLocaleString());
  e('tax-fed','$'+fed.toLocaleString());
  e('tax-state-amt','$'+stateTax.toLocaleString());
  e('tax-total','$'+total.toLocaleString());
  e('tax-quarterly-note','Set aside ~$'+Math.round(total/4).toLocaleString()+'/quarter. This is an estimate — consult your accountant.');
}

