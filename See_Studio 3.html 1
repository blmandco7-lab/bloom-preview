function loadAvailabilityReal() {
  dbGet('studio-roster', function (roster) {
    roster = roster || [];
    if (!roster.length) return; // no real creators yet -- leave illustrative example as-is
    dbGet('studio-calendar', function (calDocs) {
      calDocs = (calDocs || []).filter(function (d) { return d.from || d.to || d.reason; });
      dbGet('studio-missions', function (missionDocs) {
        missionDocs = missionDocs || [];
        try {
        var label = document.getElementById('availability-example-label');
        _toggleExampleBlock(label, false);

        var now = new Date();
        var year = now.getFullYear(), month = now.getMonth();
        var lastDay = new Date(year, month + 1, 0).getDate();
        var weeks = [
          [1, Math.min(7, lastDay)],
          [8, Math.min(14, lastDay)],
          [15, Math.min(21, lastDay)],
          [22, lastDay]
        ];
        function overlaps(fromStr, toStr, wStart, wEnd) {
          if (!fromStr && !toStr) return false;
          var f = fromStr ? new Date(fromStr) : new Date(year, month, wStart);
          var t = toStr ? new Date(toStr) : new Date(year, month, wEnd);
          var ws = new Date(year, month, wStart), we = new Date(year, month, wEnd, 23, 59, 59);
          return f <= we && t >= ws;
        }
        function isOffReason(reason) {
          return reason === 'Vacation' || reason === 'Personal' || reason === 'Creator request';
        }

        var availableCount = 0, inCampaignsCount = 0, unavailableCount = 0, overloadedCount = 0;
        var todayStr = now.toISOString().slice(0, 10);

        var rows = roster.map(function (c) {
          var myEntries = calDocs.filter(function (d) { return d.creator === c.handle; });
          var myMissions = missionDocs.filter(function (d) { return d.creator === c.handle && d.status !== 'Complete' && d.status !== 'Completed'; });
          var weekCells = weeks.map(function (w) {
            var entry = myEntries.find(function (d) { return overlaps(d.from, d.to, w[0], w[1]); });
            if (!entry) return { label: 'Free', cls: 'green' };
            return isOffReason(entry.reason) ? { label: 'Off', cls: 'red' } : { label: 'Busy', cls: 'amber' };
          });
          var activeToday = myEntries.find(function (d) {
            var f = d.from || todayStr, t = d.to || todayStr;
            return f <= todayStr && t >= todayStr;
          });
          var status, statusPill;
          if (activeToday && activeToday.reason === 'Overloaded — too many deals') { status = 'Overloaded'; statusPill = 'pa'; overloadedCount++; }
          else if (activeToday) { status = activeToday.reason || 'Unavailable'; statusPill = 'pr'; unavailableCount++; }
          else if (myMissions.length >= 3) { status = 'Overloaded'; statusPill = 'pa'; overloadedCount++; }
          else { status = 'Available'; statusPill = 'pg'; availableCount++; }
          if (myMissions.length) inCampaignsCount++;
          return { creator: c, weekCells: weekCells, campaigns: myMissions.length, status: status, statusPill: statusPill };
        });

        var availEl = document.getElementById('avail-stat-available'); if (availEl) availEl.textContent = availableCount;
        var campEl = document.getElementById('avail-stat-campaigns'); if (campEl) campEl.textContent = inCampaignsCount;
        var unavailEl = document.getElementById('avail-stat-unavailable'); if (unavailEl) unavailEl.textContent = unavailableCount;
        var overEl = document.getElementById('avail-stat-overloaded'); if (overEl) overEl.textContent = overloadedCount;

        var pillColors = { green: 'background:var(--green-bg);color:var(--green)', amber: 'background:var(--amber-bg);color:var(--amber)', red: 'background:var(--red-bg);color:var(--red)' };
        var el = document.getElementById('availability-real-list');
        if (!el) return;
        el.innerHTML = '<div class="card"><div class="ch"><div class="ct">Creator availability — ' +
          now.toLocaleString('en-US', { month: 'long' }) + ' ' + year + '</div></div><div style="padding:14px">' +
          '<div class="th-row" style="grid-template-columns:2fr 1fr 1fr 1fr 1fr 1fr 1fr"><div class="th">Creator</div><div class="th">Week 1</div><div class="th">Week 2</div><div class="th">Week 3</div><div class="th">Week 4</div><div class="th">Campaigns</div><div class="th">Status</div></div>' +
          rows.map(function (r) {
            var initials = (r.creator.handle || '?').replace('@', '').substring(0, 2).toUpperCase();
            var weekHtml = r.weekCells.map(function (w) {
              return '<div><span style="font-size:10px;' + pillColors[w.cls] + ';border-radius:4px;padding:2px 7px">' + w.label + '</span></div>';
            }).join('');
            return '<div class="tr" style="grid-template-columns:2fr 1fr 1fr 1fr 1fr 1fr 1fr"><div style="display:flex;align-items:center;gap:8px"><div class="av">' + initials + '</div><div class="tn">' + (r.creator.handle || '—') + '</div></div>' +
              weekHtml +
              '<div class="td">' + r.campaigns + ' active</div><div><span class="pill ' + r.statusPill + '">' + r.status + '</span></div></div>';
          }).join('') +
          '</div></div>' +
          (calDocs.length ? '<div class="card" style="margin-top:12px"><div class="ch"><div class="ct">Unavailability blocks</div></div>' +
            '<div class="th-row" style="grid-template-columns:1.5fr 1fr 1fr 1.5fr 50px"><div class="th">Creator</div><div class="th">From</div><div class="th">To</div><div class="th">Reason</div><div class="th"></div></div>' +
            calDocs.map(function(d) {
              return '<div class="tr" style="grid-template-columns:1.5fr 1fr 1fr 1.5fr 50px" data-id="'+d.id+'"><div class="tn">'+(d.creator||'—')+'</div><div class="td">'+(d.from||'—')+'</div><div class="td">'+(d.to||'—')+'</div><div class="td">'+(d.reason||'—')+'</div><div><button class="del-btn" data-col="studio-calendar" data-id="'+d.id+'" data-label="availability block" onclick="dbDelBtn(this)"><i class="ti ti-trash"></i></button></div></div>';
            }).join('') + '</div>' : '');
        } catch (err) {
          console.error('Availability calendar render error:', err);
          var el2 = document.getElementById('availability-real-list');
          if (el2) el2.innerHTML = '<div class="danger-notice"><i class="ti ti-alert-circle"></i><div>Something went wrong loading real availability data. Try refreshing — if this keeps happening, one of your roster or calendar records may have an unusual value in it.</div></div>';
        }
      });
    });
  });
}
