function recalcPipelineStats() {
  dbGet(COLS.deals, function(docs) {
    docs = docs || [];
    var els = document.querySelectorAll('#s-deal-pipeline .pipeline-stage .stage-count');
    if (!docs.length) {
      els.forEach(function(el){ el.textContent = '0'; });
      return;
    }
    dbGet('studio-invoices', function(invDocs) {
      invDocs = invDocs || [];
      var counts = {all:docs.length, lead:0, pitched:0, negotiating:0, contracted:0, live:0, complete:0, paid:0};
      docs.forEach(function(d) {
        var s = (d.stage||'').toLowerCase();
        if (counts.hasOwnProperty(s) && s!=='paid') counts[s]++;
        else if (s==='completed') counts.complete++;
        if (s==='completed' && invDocs.some(function(inv){ return inv.status==='Paid' && inv.to===d.brand && (inv.forWork||'').indexOf(d.creator||'\0')!==-1; })) counts.paid++;
      });
      var order = ['all','lead','pitched','negotiating','contracted','live','complete','paid'];
      order.forEach(function(s,i){ if (els[i]) els[i].textContent = counts[s]; });
    });
  });
}
function filterPipeline(stage) {
  var order = ['all','lead','pitched','negotiating','contracted','live','complete','paid'];
  document.querySelectorAll('#s-deal-pipeline .pipeline-stage').forEach(function(el,i){ el.classList.toggle('active-stage', order[i]===stage); });
  dbGet(COLS.deals, function(docs) {
    docs = docs || [];
    if (stage==='paid') {
      dbGet('studio-invoices', function(invDocs) {
        invDocs = invDocs || [];
        var paidDeals = docs.filter(function(d){ return invDocs.some(function(inv){ return inv.status==='Paid' && inv.to===d.brand && (inv.forWork||'').indexOf(d.creator||'\0')!==-1; }); });
        _renderPipelineList(paidDeals, docs);
      });
      return;
    }
    var stageMap = {lead:'Lead',pitched:'Pitched',negotiating:'Negotiating',contracted:'Contracted',live:'Live',complete:'Completed'};
    var filtered = stage==='all' ? docs : docs.filter(function(d){ return d.stage===stageMap[stage]; });
    _renderPipelineList(filtered, docs);
  });
}
