function findUGCBrands() {
  var niche = document.getElementById('ugc-niche-input').value;
  var results = document.getElementById('ugc-brand-results');
  results.innerHTML = '<div style="padding:16px;text-align:center;color:var(--gold);font-size:12px"><i class="ti ti-loader" style="animation:spin 1s linear infinite"></i> Searching for UGC brands in '+niche+'...</div>';
  var prompt = 'You help a talent agency find brands that actively run UGC (user-generated content) or creator partnership programs. '+
    'List 6 real, currently well-known brands in the "'+niche+'" category that are known for working with UGC creators or running influencer/affiliate programs. '+
    'Respond ONLY with a raw JSON array, no markdown, no code fences, no preamble. Each item: {"brand":"Brand Name","why":"one sentence on why they are a good UGC fit","approach":"one sentence tip on how to reach out to them"}.';
  callGemini(prompt, function(text) {
    var brands = null;
    try {
      var clean = text.replace(/```json|```/g,'').trim();
      brands = JSON.parse(clean);
    } catch(e) { brands = null; }
    if (!brands || !brands.length) {
      results.innerHTML = '<div style="padding:16px;text-align:center;color:var(--text3);font-size:12px">Could not parse results. Try again or pick a different niche.</div>';
      return;
    }
    results.innerHTML = brands.map(function(b) {
      return '<div class="ccard" style="margin-bottom:8px"><div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px">'+
        '<div style="flex:1"><div style="font-size:13px;font-weight:500;color:var(--text);margin-bottom:4px">'+(b.brand||'Unknown')+'</div>'+
        '<div style="font-size:11px;color:var(--text2);line-height:1.6">'+(b.why||'')+'</div>'+
        '<div style="font-size:11px;color:var(--gold);line-height:1.6;margin-top:4px"><i class="ti ti-bulb"></i> '+(b.approach||'')+'</div></div>'+
        '<button class="btn-n" style="font-size:10px;padding:5px 10px;white-space:nowrap" onclick="openAddBrandFromScout(\''+(b.brand||'').replace(/'/g,"\\'")+'\',\''+niche.replace(/'/g,"\\'")+'\')"><i class="ti ti-plus"></i>Add to CRM</button>'+
        '</div></div>';
    }).join('');
  }, function(err) {
    results.innerHTML = '<div style="padding:16px;text-align:center;color:var(--red);font-size:12px">Error: '+err+'<br><span style="color:var(--text3);font-size:11px">Add your Gemini key in Integrations first.</span></div>';
  });
}
function callGemini(prompt, onSuccess, onError) {
  var key = ''; try { key = localStorage.getItem('bloom_gemini_key') || ''; } catch(e) {}
  if (!key) { if(onError) onError('No Gemini key. Add it in Integrations.'); return; }
  // Use gemini-pro or gemini-1.5-flash-latest
  var url = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=' + key;
  fetch(url, {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({contents:[{parts:[{text:prompt}]}], generationConfig:{maxOutputTokens:800, temperature:0.7}})
  }).then(function(r){ return r.json(); })
  .then(function(d){
    if (d.error) { if(onError) onError(d.error.message); return; }
    var text = d.candidates&&d.candidates[0]&&d.candidates[0].content&&d.candidates[0].content.parts&&d.candidates[0].content.parts[0] ? d.candidates[0].content.parts[0].text : '';
    if (onSuccess) onSuccess(text);
  }).catch(function(e){ if(onError) onError(e.message); });
}



