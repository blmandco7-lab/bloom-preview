function deleteRow(btn, col, id, label) {
  _delTarget = btn;
  _delCol = col;
  _delId = id;
  var m = document.getElementById('delModal');
  if (!m) return;
  var msg = document.getElementById('delMsg');
  if (msg) msg.textContent = 'Remove this ' + (label||'record') + '? This cannot be undone.';
  m.style.display = 'flex';
}
var _delCol = null;
var _delId = null;

// Override doDelete to use Firebase
function _rowFingerprint(row, key) {
  var txt = (row.textContent||'').replace(/\s+/g,' ').trim().substring(0,120);
  var h = 0; for (var i=0;i<txt.length;i++){ h = ((h<<5)-h+txt.charCodeAt(i))|0; }
  return (key||'')+'::'+h;
}
function _getDismissedRows() { try { return JSON.parse(localStorage.getItem('bloom_dismissed_rows')||'[]'); } catch(e) { return []; } }
function _addDismissedRow(fp) { try { var arr=_getDismissedRows(); if(arr.indexOf(fp)===-1){ arr.push(fp); localStorage.setItem('bloom_dismissed_rows', JSON.stringify(arr.slice(-1000))); } } catch(e) {} }
function applyDismissedRows() {
  try {
    var dismissed = _getDismissedRows();
    if (!dismissed.length) return;
    var dset = {}; dismissed.forEach(function(f){ dset[f]=true; });
    document.querySelectorAll('[onclick^="confirmDel("]').forEach(function(btn){
      var row = btn.closest ? btn.closest('.tr,.ccard,.kb-article,.card,.mis,.panel,.cal-event-card,.bot-card,.msg-thread,.al') : null;
      if (!row || row.style.display==='none') return;
      var screen = row.closest('.screen'); var skey = screen ? screen.id : '';
      var fp = _rowFingerprint(row, skey);
      if (dset[fp]) row.style.display='none';
    });
  } catch(e) {}
}
function doDelete() {
  if (_delId && _delCol) {
    if (_delCol === 'studio-roster') {
      // Log the loss before the record disappears, so the daily briefing can
      // show how many creators came and went, not just the current count.
      dbGet('studio-roster', function (docs) {
        var leaving = (docs || []).find(function (d) { return d.id === _delId; });
        dbAdd('studio-roster-changes', { handle: leaving ? leaving.handle : '—', action: 'removed' }, function () {});
      });
    }
    dbDelete(_delCol, _delId, function() {
      if (_delCol === 'studio-notifications') updateNotificationBadge();
      if (_delTarget) {
        var row = _delTarget.closest ? _delTarget.closest('.tr,.ccard,.kb-article,.card,.mis,.panel,.cal-event-card,.bot-card,.msg-thread,.al') : null;
        if (row) { row.style.opacity = '0'; row.style.transition = 'opacity .3s'; setTimeout(function(){ if(row.parentNode) row.parentNode.removeChild(row); }, 300); }
      }
      showToast('Deleted');
      closeDelModal();
      _delTarget = null; _delCol = null; _delId = null;
    }, function(e) {
      showToast("Couldn't delete — check your connection and try again", 'error');
      closeDelModal();
      _delTarget = null; _delCol = null; _delId = null;
    });
    return;
  } else if (_delTarget) {
    var row = _delTarget.closest ? _delTarget.closest('.tr,.ccard,.kb-article,.card,.mis,.panel,.cal-event-card,.bot-card,.msg-thread,.al') : null;
    if (row) {
      var screen = row.closest('.screen'); var skey = screen ? screen.id : '';
      _addDismissedRow(_rowFingerprint(row, skey));
      row.style.opacity='0'; row.style.transition='opacity .3s'; setTimeout(function(){ if(row.parentNode) row.parentNode.removeChild(row); },300);
    }
    showToast('Removed');
  }
  closeDelModal();
  _delTarget = null; _delCol = null; _delId = null;
}

