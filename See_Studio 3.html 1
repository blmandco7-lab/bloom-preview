    '<style>body{font-family:Georgia,serif;max-width:650px;margin:40px auto;line-height:1.7;color:#111}h1{font-size:18px;text-transform:uppercase;letter-spacing:1px;text-align:center}</style></head><body>'+
    '<h1>Non-Disclosure Agreement</h1>'+
    '<p>This Non-Disclosure Agreement ("Agreement") is entered into as of '+new Date().toLocaleDateString()+' between '+agencyName+' ("Disclosing Party") and <strong>'+(d.party||'—')+'</strong> ("Receiving Party").</p>'+
    '<p><strong>1. TYPE:</strong> '+(d.ndatype||'Mutual NDA')+'</p>'+
    '<p><strong>2. CONFIDENTIAL INFORMATION:</strong> Receiving Party agrees to keep confidential the following: '+(d.covers||'client lists, deal terms, creator identities, and other proprietary business information')+'.</p>'+
    '<p><strong>3. TERM:</strong> This Agreement remains in effect '+(d.expiry?'until '+d.expiry:'indefinitely, or until information is no longer confidential by other means')+'.</p>'+
    '<p><strong>4. OBLIGATIONS:</strong> Receiving Party shall not disclose, share, or use the confidential information for any purpose other than the business relationship with '+agencyName+'.</p>'+
    '<p style="margin-top:50px">Signed:</p>'+
    '<p>_____________________&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;_____________________<br>'+(d.party||'—')+'&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;'+agencyName+'</p>'+
    '<p style="margin-top:30px;color:#666;font-size:12px">This is a template agreement. Consult an attorney before relying on it for legal protection.</p>'+
    '</body></html>';
  var blob = new Blob([html], {type:'text/html'});
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url; a.download = 'nda_'+(d.party||'agreement').replace(/\s/g,'_').replace('@','')+'.html';
