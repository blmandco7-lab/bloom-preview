function generateRealAlerts() {
  var el = document.getElementById('real-alerts-list');
  if (!el) return;
  var alerts = [];
  var pending = 3; // number of async data sources to wait for

  function checkDone() {
    pending--;
    if (pending > 0) return;
    var label = document.getElementById('briefing-alerts-example-label');
    if (!alerts.length) { el.innerHTML = ''; _toggleExampleBlock(label, true); return; }
    _toggleExampleBlock(label, false);
    alerts.sort(function(a,b){ return a.severity - b.severity; });
    el.innerHTML = alerts.map(function(a) {
      return '<div class="al '+a.cls+'"><i class="ti '+a.icon+' al-icon" style="color:var('+a.color+')"></i><div class="al-body"><div class="al-title">'+a.title+'</div><div class="al-sub">'+a.sub+'</div></div></div>';
    }).join('');
