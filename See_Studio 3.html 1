    return '<div style="font-size:10px;color:'+(isToday?'var(--gold)':'var(--text3)')+';text-align:center;padding:4px;font-weight:'+(isToday?'600':'400')+'">'+dayNames[i]+' '+d.getDate()+'</div>';
  }).join('');
  if (labelEl) labelEl.textContent = 'Week of '+days[0].toLocaleDateString('en-US',{month:'long',day:'numeric'})+' – '+days[6].toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
