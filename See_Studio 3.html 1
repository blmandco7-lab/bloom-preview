  fetch('https://graph.facebook.com/v18.0/ads_archive?access_token='+token+'&ad_type=ALL&ad_reached_countries=["US"]&search_terms='+encodeURIComponent(searchQ)+'&fields=page_name,page_id,ad_snapshot_url,ad_creative_bodies&limit=20')
