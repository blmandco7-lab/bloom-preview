var currentReviewVideoUrl = '';
function loadReviewVideo() {
  var url = document.getElementById('vr-video-url').value.trim();
  if (!url) { showToast('Paste a video link first','error'); return; }
  currentReviewVideoUrl = url;
  var vid = document.getElementById('vr-video');
  var noVid = document.getElementById('vr-no-video');
  if (vid) { vid.src = url; vid.style.display = 'block'; }
  if (noVid) noVid.style.display = 'none';
  loadVideoNotes();
}
function formatVideoTime(sec) {
  sec = Math.floor(sec);
  var m = Math.floor(sec/60), s = sec%60;
  return m+':'+(s<10?'0':'')+s;
}
function captureVideoTimestamp(event) {
  var vid = document.getElementById('vr-video');
  if (!vid || !vid.src) return;
  vid.pause();
  var time = vid.currentTime;
  showModal({title:'Add note at '+formatVideoTime(time),icon:'message-circle',submit:'Save note',fields:[
    {label:'What needs to change?',id:'note',type:'textarea',rows:3,placeholder:'e.g. Make the logo bigger here'}
  ],onSubmit:function(d){
    dbAdd('studio-video-notes', {videoUrl: currentReviewVideoUrl, brand: (currentUser&&currentUser.name)||'—', timestamp: time, note: d.note}, function(){
      showToast('Note saved at '+formatVideoTime(time));
      loadVideoNotes();
    });
  }});
}
function jumpToVideoTime(sec) {
  var vid = document.getElementById('vr-video');
  if (vid) { vid.currentTime = sec; vid.play(); }
}
function loadVideoNotes() {
  dbGet('studio-video-notes', function(allDocs) {
    var docs = (allDocs||[]).filter(function(d){ return d.videoUrl === currentReviewVideoUrl; }).sort(function(a,b){ return a.timestamp - b.timestamp; });
    var el = document.getElementById('vr-notes-list');
    if (!el) return;
    if (!docs.length) { el.innerHTML = 'No notes yet — click the video to add one'; return; }
    el.innerHTML = docs.map(function(d) {
      return '<div class="tr" style="display:flex;gap:10px;padding:8px 0;border-bottom:0.5px solid var(--border)" data-id="'+d.id+'"><button class="pill pgold" style="cursor:pointer;border:none;flex-shrink:0" onclick="jumpToVideoTime('+d.timestamp+')">'+formatVideoTime(d.timestamp)+'</button><div style="flex:1;font-size:11px;color:var(--text2)">'+d.note+'</div><button class="del-btn" data-col="studio-video-notes" data-id="'+d.id+'" onclick="dbDelBtn(this)" style="padding:2px 5px;flex-shrink:0"><i class="ti ti-trash" style="font-size:10px"></i></button></div>';
