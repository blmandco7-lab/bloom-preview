    var keys=Object.keys(docs[0]).filter(function(k){return k!=='id'&&!k.startsWith('_');});
    var csv=keys.join(',')+'\n';
    docs.forEach(function(d){csv+=keys.map(function(k){return '"'+(d[k]||'').toString().replace(/"/g,'""')+'"';}).join(',')+'\n';});
    var blob=new Blob([csv],{type:'text/csv'});
    var url=URL.createObjectURL(blob);
    var a=document.createElement('a');a.href=url;a.download=(filename||collection)+'.csv';a.click();URL.revokeObjectURL(url);
    showToast('CSV exported');
  });
}

// ============================================================
// BLOOM STUDIO — REAL AUTHENTICATION ENGINE
// ============================================================
// Replaces the old code-comparison login with real Firebase
// Authentication. Runs entirely on the free plan -- no Cloud
// Functions, no Blaze billing.
//
// HOW SIGN-IN WORKS NOW:
//   1. Person enters their email + their access code (used as
//      their real password) on the existing login screen.
//   2. Firebase itself verifies it -- not a string comparison in
//      the browser.
//   3. Once verified, we look up studio-user-roles/{their uid}
//      to find out their role and, if they're a creator/brand/
//      sub-agency, which specific record is theirs.
//
// HOW NEW ACCOUNTS GET CREATED:
//   The director calls createRealAccount(email, code, ...) when
//   adding a team member / creator / brand / sub-agency. It signs
//   the new person up through a SEPARATE, temporary connection to
//   Firebase, so the director's own session is never touched or
//   logged out. Then assignRole() writes their role as a normal
//   Firestore document -- the same way any other save in this app
//   already works, no special permissions needed beyond the
//   director already being recognized as director.
// ============================================================

// ---- Secondary Firebase connection, used only for creating OTHER people's accounts ----
function _getSecondaryAuth() {
  var secondaryApp;
  try {
    secondaryApp = firebase.app('secondary');
  } catch (e) {
    secondaryApp = firebase.initializeApp(fbConfig, 'secondary');
  }
  return secondaryApp.auth();
}

// Creates a real sign-in account for someone else. Does NOT touch
// whoever is currently signed in on the main connection.
function createRealAccount(email, code, onSuccess, onError) {
  if (!email || !code || code.length < 6) {
    if (onError) onError({ message: 'Email is required and the code must be at least 6 characters.' });
    return;
  }
  var secondaryAuth = _getSecondaryAuth();
  secondaryAuth.createUserWithEmailAndPassword(email, code)
    .then(function (cred) {
      var uid = cred.user.uid;
      secondaryAuth.signOut().then(function () {
        if (onSuccess) onSuccess(uid);
      });
    })
    .catch(function (err) {
      if (onError) onError(err);
    });
}

// Writes the role-assignment document for a given uid. Only succeeds
// if the signed-in user is recognized as director by the security
// rules -- anyone else attempting this gets a permission-denied error,
// which is correct and expected.
function loadUserAccounts() {
  var el = document.getElementById('user-accounts-list');
  if (!el || !db) return;
  db.collection('studio-user-roles').get().then(function (snap) {
    var docs = [];
    snap.forEach(function (doc) { docs.push(Object.assign({ uid: doc.id }, doc.data())); });
    if (!docs.length) { el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--text3);font-size:12px">No real accounts yet.</div>'; return; }
    var roleLabel = { director: 'Director', agentmgr: 'Agent Manager', agent: 'Agent', creator: 'Creator', brand: 'Brand', agency: 'Agency', subagency: 'Sub-agency' };
    var roleColor = { director: 'pgold', agentmgr: 'pg', agent: 'pg', creator: 'pb', brand: 'pgold', agency: 'pp', subagency: 'pp' };
    docs.sort(function (a, b) { return (b.createdAt || '').localeCompare(a.createdAt || ''); });
    el.innerHTML = '<div class="card"><div class="th-row" style="grid-template-columns:1.5fr 1fr 1.5fr 1fr 1fr 90px"><div class="th">Name</div><div class="th">Role</div><div class="th">Email</div><div class="th">Added</div><div class="th">Status</div><div class="th"></div></div>' +
      docs.map(function (d) {
        var isActive = d.active !== false;
        var name = d.linkedName || (d.role === 'director' ? 'Director' : d.email) || '—';
        return '<div class="tr" style="grid-template-columns:1.5fr 1fr 1.5fr 1fr 1fr 90px 50px" data-uid="'+d.uid+'"><div style="display:flex;align-items:center;gap:8px"><div class="av">'+name.replace('@','').substring(0,2).toUpperCase()+'</div><div class="tn">'+name+'</div></div><div><span class="pill '+(roleColor[d.role]||'pb')+'">'+(roleLabel[d.role]||d.role||'—')+'</span></div><div class="td" style="font-size:11px">'+(d.email||'—')+'</div><div class="td" style="font-size:11px">'+(d.createdAt?new Date(d.createdAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}):'—')+'</div><div><span class="pill '+(isActive?'pg':'pr')+'">'+(isActive?'Active':'Revoked')+'</span></div><div>'+(d.role==='director'?'':'<button class="'+(isActive?'btn-r':'btn-g')+'" style="font-size:10px;padding:4px 8px" onclick="toggleUserAccountAccess(\''+d.uid+'\','+(!isActive)+')">'+(isActive?'Revoke':'Restore')+'</button>')+'</div><div>'+(d.role==='director'?'':'<button class="del-btn" onclick="deleteUserAccountRecord(\''+d.uid+'\',\''+name.replace(/'/g,"\\'")+'\')"><i class="ti ti-trash"></i></button>')+'</div></div>';
      }).join('') + '</div>';
  }).catch(function () { el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--red);font-size:12px">Could not load accounts.</div>'; });
}
function deleteUserAccountRecord(uid, name) {
  if (!confirm('Delete ' + name + '\'s access record? This removes their role/permissions entirely — same effect as revoking, but removes them from this list too. To fully delete the login itself, also remove them in Firebase Console → Authentication → Users.')) return;
  db.collection('studio-user-roles').doc(uid).delete().then(function () {
    showToast('Access record deleted for ' + name);
    logAuditEvent('User account deleted', name + ' (UID ' + uid + ')', currentRole);
    loadUserAccounts();
  }).catch(function () { showToast('Could not delete — try again', 'error'); });
}
function toggleUserAccountAccess(uid, makeActive) {
  if (!makeActive) {
    if (!confirm('Revoke this person\'s access? They\'ll be signed out immediately and won\'t be able to sign back in until you restore it.')) return;
  }
  db.collection('studio-user-roles').doc(uid).set({ active: makeActive }, { merge: true }).then(function () {
    showToast(makeActive ? 'Access restored' : 'Access revoked');
    logAuditEvent(makeActive ? 'Account access restored' : 'Account access revoked', 'UID '+uid, currentRole);
    loadUserAccounts();
  }).catch(function () { showToast('Could not update — try again', 'error'); });
}
function assignRole(uid, roleFields, onSuccess, onError) {
  var data = Object.assign({ active: true }, roleFields);
  db.collection('studio-user-roles').doc(uid).set(data)
    .then(function () { if (onSuccess) onSuccess(); })
    .catch(function (err) { if (onError) onError(err); });
}

// Convenience wrapper: create the account AND assign the role in one call.
// roleFields example: { role: 'creator', linkedId: rosterDocId, linkedName: '@alexjones' }
function createRealAccountWithRole(email, code, roleFields, onSuccess, onError) {
  createRealAccount(email, code, function (uid) {
    var fields = Object.assign({ email: email, createdAt: new Date().toISOString(), createdBy: (currentUser&&currentUser.name)||currentRole }, roleFields);
    assignRole(uid, fields, function () {
      addNotificationForDirector('New account created', (fields.linkedName||email)+' ('+(fields.role||'')+') was given access.', 'info');
      if (onSuccess) onSuccess(uid);
    }, onError);
  }, onError);
}

// ---- Real sign-in (replaces doLogin() / doBrandLogin()) ----
function doRealLogin() {
  var emailEl = document.getElementById('loginEmail');
  var pwdEl = document.getElementById('loginPassword');
  if (!emailEl || !pwdEl) return;
  if (!_checkLoginThrottle('loginErr')) return;
  var email = emailEl.value.trim();
  var code = pwdEl.value.trim();
  if (!email || !code) return;
  var submitBtn = document.querySelector('#loginPage button[onclick="doRealLogin()"]');
  if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Signing in...'; }

  function fail(msg) {
    if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Sign in'; }
    _recordLoginFailure();
    var err = document.getElementById('loginErr');
    if (err) {
      err.textContent = msg || 'Incorrect email or code. Please try again.';
      err.style.display = 'block';
      setTimeout(function () { err.style.display = 'none'; }, 3500);
    }
  }

  firebase.auth().signInWithEmailAndPassword(email, code)
    .then(function (cred) {
      return db.collection('studio-user-roles').doc(cred.user.uid).get();
    })
    .then(function (roleDoc) {
      if (!roleDoc.exists || roleDoc.data().active === false) {
        firebase.auth().signOut();
        fail('This account has no access assigned yet. Check with your director.');
        return;
      }
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Sign in'; }
      _recordLoginSuccess();
      finishRealLogin(roleDoc.data());
    })
    .catch(function () {
      fail('Incorrect email or code. Please try again.');
    });
}

// After a verified sign-in, load the person's own linked record (their
// roster entry, brand entry, team-member entry, sub-agency entry) so
// currentUser is genuinely populated -- this is also what fixes creator/
// brand dashboards that used to show permanently fake placeholder data,
// since previously those roles had no real per-person identity at all.
function finishRealLogin(roleData) {
  currentRole = roleData.role;
  selectedLoginRole = roleData.role;

  function proceed(userRecord) {
    currentUser = userRecord;
    logAuditEvent('Signed in', (userRecord && userRecord.name ? userRecord.name : roleData.role) + ' logged in as ' + roleData.role, roleData.role);
    var vas = document.getElementById('viewAsSelector');
    if (vas) vas.style.display = (roleData.role === 'director') ? 'flex' : 'none';
    if (roleData.role === 'subagency') { try { loadSubAgencyConfig(); } catch (e2) {} }
    var lp = document.getElementById('loginPage');
    var land = document.getElementById('landingPage');
    var appTopbar = document.getElementById('appTopbar');
    var appBody = document.getElementById('appBody');
    if (lp) lp.style.display = 'none';
    if (land) land.style.display = 'none';
    if (appTopbar) appTopbar.style.display = 'flex';
    if (appBody) appBody.style.display = 'flex';
    buildSidebar(currentRole);
    buildRoleSwitcher(currentRole);
    updateSidebarFooter(currentRole);
    try { applyCreatorIdentity(); } catch (e3) {}
    try { updateNotificationBadge(); } catch (e4) {}
    var _ds = roleDefaults[currentRole] || 'briefing';
    saveLoginState(currentRole, _ds);
    nav(_ds);
  }

  var lookupCollection = {
    creator: 'studio-roster',
    brand: 'studio-brand-directory',
    subagency: 'studio-sub-agencies',
    agent: 'studio-team-members',
    agentmgr: 'studio-team-members'
  }[roleData.role];
  if (roleData.linkedId && lookupCollection) {
    db.collection(lookupCollection).doc(roleData.linkedId).get()
      .then(function (doc) {
        var record = doc.exists ? Object.assign({ id: doc.id, role: roleData.role }, doc.data()) : null;
        proceed(record);
      })
      .catch(function () { proceed(null); });
  } else {
    proceed(null); // director has no separate linked record -- expected
  }
}

// ---- Director's own one-time sign-up ----
function submitDirectorSignup(d) {
  if (!d.email || !d.password || d.password.length < 6) {
    showToast('Enter a valid email and a password of at least 6 characters.', 'error');
    return;
  }
  firebase.auth().createUserWithEmailAndPassword(d.email.trim(), d.password.trim())
    .then(function (cred) {
      showToast('Account created. Your sign-in ID is ' + cred.user.uid + ' -- see the console step to finish setup.', 'success');
      console.log('DIRECTOR UID (copy this for the Firebase Console bootstrap step):', cred.user.uid);
    })
    .catch(function (err) {
      showToast(err.message, 'error');
    });
}
function openDirectorSignup() {
  showModal({
    title: 'Create your director account',
    icon: 'user-plus',
    submit: 'Create account',
    desc: "One-time setup. After this, you'll finish activating it with one manual step in the Firebase console.",
    fields: [
      { label: 'Your email', id: 'email', type: 'email', placeholder: 'you@example.com' },
      { label: 'Choose a password (6+ characters)', id: 'password', type: 'password', placeholder: 'Not your access code -- your real login password' }
    ],
    onSubmit: submitDirectorSignup
  });
}
