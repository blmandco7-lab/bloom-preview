    }
    gridEl.innerHTML = days.map(function(d) {
      var dayPosts = docs.filter(function(p){ var pd = parseLocalDate(p.date); return pd && pd.toDateString()===d.toDateString(); });
      var events = dayPosts.map(function(p){
