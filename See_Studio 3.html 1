function releaseEscrowMilestone(id, milestoneNum) {
  dbGet('studio-escrow', function(docs) {
    var rec = (docs||[]).find(function(d){ return d.id===id; });
    if (!rec) return;
    var update = {};
    var pct, label;
    if (milestoneNum === 1) { update.m1released = true; pct = rec.m1pct; label = rec.m1label; }
    else { update.m2released = true; pct = rec.m2pct; label = rec.m2label; }
    var amt = parseFloat(rec.amount||0) * parseFloat(pct||50)/100;
    var allReleased = (milestoneNum===1 ? true : !!rec.m1released) && (milestoneNum===2 ? true : !!rec.m2released);
    if (allReleased) update.status = 'Released to creator';
    dbUpdate('studio-escrow', id, update, function(){
      showToast('$'+amt.toLocaleString()+' released for '+(label||'milestone'));
      logAuditEvent('Escrow milestone released', (rec.creator||'creator')+' — '+(label||'')+' — $'+amt.toLocaleString(), currentRole);
      // This was previously the missing piece: releasing a milestone only
      // updated the escrow record itself, so it never actually reached the
      // creator's real earnings anywhere else in the app. Now it does.
      dbAdd('studio-payments', { creator: rec.creator, amount: amt, status: 'Paid', notes: (rec.brand||'')+' — '+(label||'milestone')+' (escrow release)' }, function(){});
      loadEscrowRecords();
    });
  });
}
