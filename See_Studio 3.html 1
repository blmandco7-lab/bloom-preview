function anonymizeCreatorId(handle) {
  var hash = 0;
  for (var i=0; i<handle.length; i++) { hash = ((hash << 5) - hash + handle.charCodeAt(i)) | 0; }
  var num = Math.abs(hash) % 9000 + 1000;
  return 'Creator #'+num;
}
