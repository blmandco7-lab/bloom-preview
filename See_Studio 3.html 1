// ── LOGIN THROTTLING ──
// This only slows down guessing through the login *form*. It cannot stop someone
// who opens devtools and reads `passwords` directly, or calls finishTeamLogin()
// from the console — that requires moving verification to a server (see the
// SECURITY_README note shipped alongside this file).
function _loginAttemptState() {
  try { return JSON.parse(sessionStorage.getItem('bloom_login_attempts') || '{"count":0,"until":0}'); }
  catch(e) { return {count:0, until:0}; }
}
function _setLoginAttemptState(s) {
  try { sessionStorage.setItem('bloom_login_attempts', JSON.stringify(s)); } catch(e) {}
}
function _checkLoginThrottle(errElId) {
  var s = _loginAttemptState();
  if (s.until && Date.now() < s.until) {
    var err = document.getElementById(errElId);
    if (err) {
      var secs = Math.ceil((s.until - Date.now())/1000);
      err.textContent = 'Too many attempts. Try again in ' + secs + 's.';
      err.style.display = 'block';
    }
    return false;
  }
  return true;
}
function _recordLoginFailure() {
  var s = _loginAttemptState();
  s.count = (s.count||0) + 1;
  if (s.count >= 5) { s.until = Date.now() + 30000; s.count = 0; }
  _setLoginAttemptState(s);
}
function _recordLoginSuccess() { _setLoginAttemptState({count:0, until:0}); }
function doLogin() {
  var pwdEl=document.getElementById('loginPassword');
  if(!pwdEl) return;
  if (!_checkLoginThrottle('loginErr')) return;
  var pwd=pwdEl.value.trim();
  if (!pwd) return;
  var matched=null;
  // Agent Manager, Agent, and Sub-agency no longer accept the shared role code —
  // only an individual account (created via 'Add team member' / 'Add sub-agency')
  // works for these three roles now. Director, Agency partner, Brand, and Creator
  // still accept their shared codes.
  var noSharedLogin = {agentmgr:1, agent:1, subagency:1};
  Object.keys(passwords).forEach(function(r){ if(!noSharedLogin[r] && pwd===passwords[r]) matched=r; });
  if (matched) { _recordLoginSuccess(); finishTeamLogin(matched, null); return; }
  // Not a shared role password — check individual team member codes, fetching fresh
  // in case teamMembers hasn't finished its initial async load yet.
  var submitBtn = document.querySelector('#loginPage button[onclick="doLogin()"]');
  if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Signing in...'; }
  dbGetAll('studio-team-members', function(freshMembers) {
    if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Sign in'; }
    var m2=null, mu2=null;
    (freshMembers||[]).forEach(function(m){ if(m.accessCode && pwd===m.accessCode && m.status!=='Inactive'){ m2=m.role; mu2=m; } });
    if (!m2) {
      _recordLoginFailure();
      var err=document.getElementById('loginErr');
      if(err) { err.textContent='Incorrect access code. Please try again.'; err.style.display='block'; setTimeout(function(){ err.style.display='none'; },3000); }
      return;
    }
    _recordLoginSuccess();
    finishTeamLogin(m2, mu2);
  });
}
