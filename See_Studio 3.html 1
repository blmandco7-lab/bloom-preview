function loadSOPProgressData(cb) {
  if (db) {
    db.collection('studio-config').doc('sop-progress').get().then(function(doc){
      cb(doc.exists ? doc.data() : {});
    }).catch(function(){
      try { cb(JSON.parse(localStorage.getItem('bloom_sop_progress')||'{}')); } catch(e) { cb({}); }
    });
  } else {
    try { cb(JSON.parse(localStorage.getItem('bloom_sop_progress')||'{}')); } catch(e) { cb({}); }
  }
}
function renderSOPProgress(all) {
  Object.keys(SOP_STEP_COUNTS).forEach(function(procKey) {
    var total = SOP_STEP_COUNTS[procKey];
    var stepsDone = all[procKey] || {};
    var doneCount = 0;
    for (var i=1; i<=total; i++) {
      var stepEl = document.querySelector('.sop-step[data-proc="'+procKey+'"][data-step="'+i+'"] .sop-check');
      var isDone = !!stepsDone[i];
      if (isDone) doneCount++;
      if (stepEl) {
        if (isDone) { stepEl.innerHTML = '<i class="ti ti-check"></i>'; stepEl.style.background = 'var(--green)'; stepEl.style.color = '#fff'; }
        else { stepEl.textContent = i; stepEl.style.background = procKey==='crisis-protocol' ? 'var(--red-bg)' : 'var(--gold-dim)'; stepEl.style.color = procKey==='crisis-protocol' ? 'var(--red)' : 'var(--gold)'; }
      }
    }
    var progEl = document.getElementById('sop-progress-'+procKey);
    if (progEl) progEl.textContent = doneCount+' of '+total+' complete'+(doneCount===total ? ' ✓' : '');
  });
}
