function attachSwipeDrag() {
  var card = document.querySelector('.swipe-card');
  if (!card) return;
  var startX = 0, curX = 0, dragging = false;
  function start(x) { dragging = true; startX = x; card.style.transition = 'none'; }
  function move(x) {
    if (!dragging) return;
    curX = x - startX;
    card.style.transform = 'translateX('+curX+'px) rotate('+(curX/18)+'deg)';
    var likeStamp = card.querySelector('.swipe-stamp-like'), passStamp = card.querySelector('.swipe-stamp-pass');
    if (likeStamp) likeStamp.style.opacity = Math.max(0, Math.min(1, curX/80));
    if (passStamp) passStamp.style.opacity = Math.max(0, Math.min(1, -curX/80));
  }
  function end() {
    if (!dragging) return;
    dragging = false;
    card.style.transition = 'transform .3s ease';
    if (curX > 100) { swipeTopCard('right'); }
    else if (curX < -100) { swipeTopCard('left'); }
    else { card.style.transform = 'translateX(0) rotate(0)'; }
    curX = 0;
  }
  card.addEventListener('mousedown', function(e){ start(e.clientX); });
  window.addEventListener('mousemove', function(e){ move(e.clientX); });
  window.addEventListener('mouseup', end);
  card.addEventListener('touchstart', function(e){ start(e.touches[0].clientX); });
  card.addEventListener('touchmove', function(e){ move(e.touches[0].clientX); });
  card.addEventListener('touchend', end);
}
function swipeTopCard(direction) {
